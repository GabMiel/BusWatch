<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="vertical"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:contentDescription="@string/logo"
            android:src="@drawable/logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvBusWatch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/buswatch"
            android:textColor="#000000"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="@+id/ivLogo"
            app:layout_constraintStart_toEndOf="@+id/ivLogo"
            app:layout_constraintTop_toTopOf="@+id/ivLogo" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/glStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="32dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/glEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="32dp" />

        <!-- Progress Indicators -->
        <View
            android:id="@+id/viewParent"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginTop="79dp"
            android:layout_marginStart="24dp"
            android:background="@drawable/circle_shape"
            android:backgroundTint="#FEBE1E"
            app:layout_constraintEnd_toStartOf="@+id/viewChild"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/user"
            app:layout_constraintBottom_toBottomOf="@+id/viewParent"
            app:layout_constraintEnd_toEndOf="@+id/viewParent"
            app:layout_constraintStart_toStartOf="@+id/viewParent"
            app:layout_constraintTop_toTopOf="@+id/viewParent"
            app:tint="#000000" />

        <TextView
            android:id="@+id/textView173"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/parent_information_newline"
            android:textColor="#FEBE1E"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/viewParent"
            app:layout_constraintStart_toStartOf="@+id/viewParent"
            app:layout_constraintTop_toBottomOf="@+id/viewParent" />

        <View
            android:id="@+id/viewEmergency"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/circle_shape"
            android:backgroundTint="#C4C4C4"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toEndOf="@+id/viewChild"
            app:layout_constraintTop_toTopOf="@+id/viewParent" />

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/heart"
            app:layout_constraintBottom_toBottomOf="@+id/viewEmergency"
            app:layout_constraintEnd_toEndOf="@+id/viewEmergency"
            app:layout_constraintStart_toStartOf="@+id/viewEmergency"
            app:layout_constraintTop_toTopOf="@+id/viewEmergency"
            app:tint="#000000" />

        <TextView
            android:id="@+id/textView175"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/emergency"
            android:textColor="#C4C4C4"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/viewEmergency"
            app:layout_constraintStart_toStartOf="@+id/viewEmergency"
            app:layout_constraintTop_toBottomOf="@+id/viewEmergency" />

        <View
            android:id="@+id/viewChild"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/circle_shape"
            android:backgroundTint="#C4C4C4"
            app:layout_constraintEnd_toStartOf="@+id/viewEmergency"
            app:layout_constraintStart_toEndOf="@+id/viewParent"
            app:layout_constraintTop_toTopOf="@+id/viewParent" />

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/child"
            app:layout_constraintBottom_toBottomOf="@+id/viewChild"
            app:layout_constraintEnd_toEndOf="@+id/viewChild"
            app:layout_constraintStart_toStartOf="@+id/viewChild"
            app:layout_constraintTop_toTopOf="@+id/viewChild"
            app:tint="#000000" />

        <TextView
            android:id="@+id/textView174"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/child_information_newline"
            android:textColor="#C4C4C4"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/viewChild"
            app:layout_constraintStart_toStartOf="@+id/viewChild"
            app:layout_constraintTop_toBottomOf="@+id/viewChild" />

        <!-- Connecting Lines -->
        <View
            android:id="@+id/viewProgressLine1"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:background="#C4C4C4"
            app:layout_constraintBottom_toBottomOf="@+id/viewParent"
            app:layout_constraintEnd_toStartOf="@+id/viewChild"
            app:layout_constraintStart_toEndOf="@+id/viewParent"
            app:layout_constraintTop_toTopOf="@+id/viewParent" />

        <View
            android:id="@+id/viewProgressLine2"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:background="#C4C4C4"
            app:layout_constraintBottom_toBottomOf="@+id/viewChild"
            app:layout_constraintEnd_toStartOf="@+id/viewEmergency"
            app:layout_constraintStart_toEndOf="@+id/viewChild"
            app:layout_constraintTop_toTopOf="@+id/viewChild" />

        <!-- Form Title -->
        <TextView
            android:id="@+id/tvCreateAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/create_account"
            android:textColor="#000000"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView174" />

        <!-- Avatar Section (Added) -->
        <LinearLayout
            android:id="@+id/llLabelPhoto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvCreateAccount">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_photo"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/viewParentAvatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_avatar_circle"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelPhoto">

            <ImageView
                android:id="@+id/ivParentAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_person_placeholder"
                android:scaleType="centerCrop"
                android:contentDescription="@string/avatar"
                android:padding="2dp" />
        </FrameLayout>

        <Button
            android:id="@+id/btnSignup1AddPhoto"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/textfield_shape"
            android:backgroundTint="#FFFFFF"
            android:text="@string/add_photo"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/viewParentAvatar"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toEndOf="@+id/viewParentAvatar"
            app:layout_constraintTop_toTopOf="@+id/viewParentAvatar" />

        <!-- First Name -->
        <LinearLayout
            android:id="@+id/llLabels1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/viewParentAvatar">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/first_name"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <EditText
            android:id="@+id/editTextText3"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_your_first_name"
            android:inputType="textPersonName"
            android:autofillHints="personGivenName"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabels1" />

        <TextView
            android:id="@+id/tvFirstNameWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/name_warning"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/editTextText3" />

        <!-- Last Name -->
        <LinearLayout
            android:id="@+id/llLabels2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvFirstNameWarning">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/last_name"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <EditText
            android:id="@+id/editTextText4"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_your_last_name"
            android:inputType="textPersonName"
            android:autofillHints="personFamilyName"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabels2" />

        <TextView
            android:id="@+id/tvLastNameWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/name_warning"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/editTextText4" />

        <!-- Middle Name & Suffix Row -->
        <LinearLayout
            android:id="@+id/llLabelMiddle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvLastNameWarning">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/middle_name"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/suffix"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/editTextText5"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_your_middle_name"
            android:inputType="textPersonName"
            android:autofillHints="personMiddleName"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toStartOf="@+id/btnSignup1Suffix"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelMiddle" />

        <FrameLayout
            android:id="@+id/btnSignup1Suffix"
            android:layout_width="100dp"
            android:layout_height="40dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintTop_toTopOf="@+id/editTextText5">

            <TextView
                android:id="@+id/tvSignup1SelectedSuffix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:text="@string/suffix"
                android:textColor="#888888"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/suffix"
                android:src="@drawable/ic_chevron_down"
                app:tint="#888888" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvMiddleNameWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/name_warning"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@+id/editTextText5"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/editTextText5" />

        <!-- Email -->
        <LinearLayout
            android:id="@+id/llLabels3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvMiddleNameWarning">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/email"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <EditText
            android:id="@+id/etSignup1Email"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_your_email"
            android:inputType="textEmailAddress"
            android:autofillHints="emailAddress"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabels3" />

        <TextView
            android:id="@+id/tvEmailWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/etSignup1Email" />

        <!-- Phone Number -->
        <LinearLayout
            android:id="@+id/llLabels4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvEmailWarning">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/phone_number"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llParentPhoneContainer"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabels4">

            <FrameLayout
                android:id="@+id/btnSignup1ParentCountryCode"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvSignup1ParentCountryCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/country_code_ph"
                    android:textColor="#000000"
                    android:textSize="14sp" />
            </FrameLayout>

            <EditText
                android:id="@+id/etParentPhone"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:hint="@string/phone_hint"
                android:inputType="phone"
                android:autofillHints="phoneNumber"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Password -->
        <LinearLayout
            android:id="@+id/llLabels5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llParentPhoneContainer">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/password"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/flPasswordContainer"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabels5">

            <EditText
                android:id="@+id/editTextTextPassword6"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:hint="@string/create_a_password"
                android:inputType="textPassword"
                android:autofillHints="password"
                android:paddingStart="12dp"
                android:paddingEnd="44dp"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/btnSignup1ViewPassword"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/show_password"
                android:src="@drawable/ic_eye_off"
                app:tint="#888888" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvPasswordRequirements"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/password_requirements"
            android:textColor="#888888"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/flPasswordContainer" />

        <!-- Confirm Password -->
        <LinearLayout
            android:id="@+id/llLabels6"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvPasswordRequirements">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/confirm_password"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/flConfirmPasswordContainer"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabels6">

            <EditText
                android:id="@+id/editTextTextPassword7"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:hint="@string/re_enter_password"
                android:inputType="textPassword"
                android:autofillHints="password"
                android:paddingStart="12dp"
                android:paddingEnd="44dp"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/btnSignup1ViewConfirmPassword"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/show_password"
                android:src="@drawable/ic_eye_off"
                app:tint="#888888" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/llLabelLanguage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/flConfirmPasswordContainer">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preferred_language"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/btnSignup1Language"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelLanguage">

            <TextView
                android:id="@+id/tvSignup1SelectedLanguage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:text="@string/select_language"
                android:textColor="#888888"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="12dp"
                android:contentDescription="@string/language_icon"
                android:src="@drawable/ic_chevron_down"
                app:tint="#888888" />
        </FrameLayout>

        <Button
            android:id="@+id/btnSignup1Next"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/soft_corner"
            android:backgroundTint="#000000"
            android:text="@string/next"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/btnSignup1Language" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnSignup1Next">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/already_have_an_account"
                android:textColor="#000000"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnSignup1Signin"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="4dp"
                android:paddingEnd="0dp"
                android:text="@string/log_in_caps"
                android:textColor="#FEBE1E"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
