<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/studentCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_card_black_border"
    android:padding="16dp">

    <!-- Avatar -->
    <ImageView
        android:id="@+id/imgStudent"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:background="@drawable/bg_avatar_circle"
        android:contentDescription="@string/student_avatar"
        android:scaleType="centerCrop"
        android:src="@drawable/user" />

    <!-- Status Badge -->
    <TextView
        android:id="@+id/tvStudentStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:background="@drawable/bg_button_yellow"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        android:text="@string/at_home"
        android:textAllCaps="true"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- Student Info -->
    <LinearLayout
        android:id="@+id/studentInfoContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_toEndOf="@id/imgStudent"
        android:layout_toStartOf="@id/tvStudentStatus"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvStudentName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/justin_wilson"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStudentGrade"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/grade_1"
            android:textColor="@color/black"
            android:textSize="13sp"
            android:background="@drawable/bg_tab_underline"
            android:paddingBottom="1dp" />

        <TextView
            android:id="@+id/tvStudentSchool"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/the_immaculate_mother_academy_inc"
            android:textColor="@color/black"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Options Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/studentInfoContainer"
        android:layout_marginTop="12dp"
        android:layout_alignStart="@id/studentInfoContainer"
        android:orientation="vertical">

        <!-- Ride Option -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="@string/ride_option"
                android:textColor="@color/black"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/spinnerRideOption"
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:background="@drawable/spinner_border"
                android:spinnerMode="dropdown"
                android:paddingEnd="24dp"
                tools:ignore="RtlSymmetry" />
        </LinearLayout>

        <!-- Stop -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="@string/stop"
                android:textColor="@color/black"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvStudentStop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/street_address"
                android:textColor="@color/black"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
