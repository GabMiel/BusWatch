<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_details_card"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvEditEmergencyTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/emergency"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvEmergencyFields"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fillViewport="true"
        app:layout_constrainedHeight="true"
        app:layout_constraintBottom_toTopOf="@+id/llEmergencyActions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_max="450dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvEditEmergencyTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Primary Contact Section (Parent) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/emergency_contact_1"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/first_name"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etEditParentFirstName"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/textfield_shape"
                android:backgroundTint="#F5F5F5"
                android:hint="@string/enter_your_first_name"
                android:inputType="textPersonName"
                android:autofillHints="personGivenName"
                android:paddingHorizontal="12dp"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/last_name"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etEditParentLastName"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/textfield_shape"
                android:backgroundTint="#F5F5F5"
                android:hint="@string/enter_your_last_name"
                android:inputType="textPersonName"
                android:autofillHints="personFamilyName"
                android:paddingHorizontal="12dp"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/phone_number"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etEditParentPhone"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/textfield_shape"
                android:backgroundTint="#F5F5F5"
                android:hint="@string/enter_your_phone_number"
                android:inputType="phone"
                android:autofillHints="phoneNumber"
                android:paddingHorizontal="12dp"
                android:textSize="14sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:background="#D1CFCF" />

            <!-- Emergency Contact 1 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/emergency_contact_1"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/full_name"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etEditContact1Name"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/textfield_shape"
                android:backgroundTint="#F5F5F5"
                android:hint="@string/contact_name"
                android:inputType="textPersonName"
                android:autofillHints="personName"
                android:paddingHorizontal="12dp"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/relationship"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etEditContact1Rel"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/textfield_shape"
                android:backgroundTint="#F5F5F5"
                android:hint="@string/e_g_mother_father_guardian"
                android:inputType="text"
                android:autofillHints="none"
                android:paddingHorizontal="12dp"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/phone_number"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp" />
            <EditText
                android:id="@+id/etEditContact1Phone"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/textfield_shape"
                android:backgroundTint="#F5F5F5"
                android:hint="@string/contact_phone"
                android:inputType="phone"
                android:autofillHints="phoneNumber"
                android:paddingHorizontal="12dp"
                android:textSize="14sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:background="#D1CFCF" />

            <!-- Emergency Contact 2 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/emergency_contact_2_optional"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/full_name"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etEditContact2Name"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/textfield_shape"
                android:backgroundTint="#F5F5F5"
                android:hint="@string/contact_name"
                android:inputType="textPersonName"
                android:autofillHints="personName"
                android:paddingHorizontal="12dp"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/relationship"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etEditContact2Rel"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/textfield_shape"
                android:backgroundTint="#F5F5F5"
                android:hint="@string/e_g_mother_father_guardian"
                android:inputType="text"
                android:autofillHints="none"
                android:paddingHorizontal="12dp"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/phone_number"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etEditContact2Phone"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/textfield_shape"
                android:backgroundTint="#F5F5F5"
                android:hint="@string/contact_phone"
                android:inputType="phone"
                android:autofillHints="phoneNumber"
                android:paddingHorizontal="12dp"
                android:textSize="14sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Action Buttons -->
    <LinearLayout
        android:id="@+id/llEmergencyActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal"
        android:baselineAligned="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nsvEmergencyFields">

        <Button
            android:id="@+id/btnCancelEdit"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="@string/cancel"
            android:textColor="#666666"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSaveEmergency"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:background="@drawable/soft_corner"
            android:backgroundTint="#FEBE1E"
            android:text="@string/save_caps"
            android:textColor="#000000"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>