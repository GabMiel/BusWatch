<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- 1. Header Section - Consistent with Admin View Route -->
    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/dark_header"
        android:paddingHorizontal="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnMapBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back_button"
            android:src="@drawable/ic_back"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@id/btnMapBack"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvLiveTrackingTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/live_tracking"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvChildName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_white_secondary"
                android:textSize="11sp"
                tools:text="Justin Wilson" />
        </LinearLayout>
    </RelativeLayout>

    <!-- 2. Next Stop Banner - Mirrored from Driver Side -->
    <LinearLayout
        android:id="@+id/bannerNextStop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/yellow_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:elevation="6dp"
        android:baselineAligned="false"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRouteInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="ROUTE A • BUS-001" />

            <TextView
                android:id="@+id/tvNextStopName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:text="Main Entrance Gate" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvETA"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_eta_badge"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="ETA - 10 MINS" />
    </LinearLayout>

    <!-- 3. Map Area -->
    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomInfo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bannerNextStop">

        <org.osmdroid.views.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Floating Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:gravity="end"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnMaximizeMap"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/circle_shape"
                android:backgroundTint="#CCFFFFFF"
                android:contentDescription="@string/maximize_map"
                android:elevation="4dp"
                android:padding="10dp"
                android:src="@drawable/ic_eye"
                app:tint="@color/black" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnMyLocation"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:background="@drawable/circle_shape"
            android:backgroundTint="#CCFFFFFF"
            android:contentDescription="@string/locate_bus"
            android:elevation="6dp"
            android:padding="12dp"
            android:src="@drawable/ic_my_location"
            app:tint="#4A90E2" />
    </FrameLayout>

    <!-- 4. Bottom Info Section (Driver & Bus) -->
    <RelativeLayout
        android:id="@+id/layoutBottomInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/yellow_primary"
        android:paddingBottom="24dp"
        android:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Bottom Sheet Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="8dp"
            android:background="@drawable/rectangle_shape"
            android:backgroundTint="#44000000" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="70dp">

            <TextView
                android:id="@+id/tvDriverName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="Mike Johnson" />

            <TextView
                android:id="@+id/tvBusStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/black"
                android:textSize="13sp"
                tools:text="Bus Driver • BUS-001" />

            <!-- Single Full-Width Action Button -->
            <LinearLayout
                android:id="@+id/btnMapBusDetails"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="24dp"
                android:background="@drawable/rectangle_shape_black"
                android:gravity="center"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bus_details_caps"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

    <!-- Floating Driver Avatar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvAvatarContainer"
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:cardCornerRadius="60dp"
        app:cardElevation="15dp"
        app:strokeWidth="4dp"
        app:strokeColor="@color/yellow_primary"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomInfo"
        app:cardBackgroundColor="@android:color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="-60dp">

        <ImageView
            android:id="@+id/ivDriverAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_person_placeholder"
            tools:src="@drawable/user"
            android:contentDescription="@string/avatar" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
