<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="vertical"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- Top Header consistent with signup1 and signup3 -->
        <ImageView
            android:id="@+id/imageView33"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:contentDescription="@string/logo"
            android:src="@drawable/logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/textView172"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/buswatch"
            android:textColor="#000000"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="@+id/imageView33"
            app:layout_constraintStart_toEndOf="@+id/imageView33"
            app:layout_constraintTop_toTopOf="@+id/imageView33" />

        <!-- Progress Indicators -->
        <View
            android:id="@+id/view39"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/circle_shape"
            android:backgroundTint="#FEBE1E"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="28dp"
            android:layout_marginTop="79dp" />

        <TextView
            android:id="@+id/textView173"
            android:layout_width="79dp"
            android:layout_height="34dp"
            android:text="@string/parent_information"
            android:textColor="#FEBE1E"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/view39"
            app:layout_constraintTop_toTopOf="@+id/view39"
            android:layout_marginStart="8dp" />

        <View
            android:id="@+id/view40"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/circle_shape"
            android:backgroundTint="#FEBE1E"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="149dp"
            android:layout_marginTop="79dp" />

        <TextView
            android:id="@+id/textView174"
            android:layout_width="79dp"
            android:layout_height="34dp"
            android:text="@string/child_information"
            android:textColor="#FEBE1E"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/view40"
            app:layout_constraintTop_toTopOf="@+id/view40"
            android:layout_marginStart="8dp" />

        <View
            android:id="@+id/view45"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/circle_shape"
            android:backgroundTint="#C4C4C4"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="268dp"
            android:layout_marginTop="79dp" />

        <TextView
            android:id="@+id/textView175"
            android:layout_width="79dp"
            android:layout_height="34dp"
            android:text="@string/medical_information"
            android:textColor="#C4C4C4"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/view45"
            app:layout_constraintTop_toTopOf="@+id/view45"
            android:layout_marginStart="8dp" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:src="@drawable/user"
            app:layout_constraintBottom_toBottomOf="@+id/view39"
            app:layout_constraintEnd_toEndOf="@+id/view39"
            app:layout_constraintStart_toStartOf="@+id/view39"
            app:layout_constraintTop_toTopOf="@+id/view39"
            app:tint="#000000" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:src="@drawable/child"
            app:layout_constraintBottom_toBottomOf="@+id/view40"
            app:layout_constraintEnd_toEndOf="@+id/view40"
            app:layout_constraintStart_toStartOf="@+id/view40"
            app:layout_constraintTop_toTopOf="@+id/view40"
            app:tint="#000000" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:src="@drawable/heart"
            app:layout_constraintBottom_toBottomOf="@+id/view45"
            app:layout_constraintEnd_toEndOf="@+id/view45"
            app:layout_constraintStart_toStartOf="@+id/view45"
            app:layout_constraintTop_toTopOf="@+id/view45"
            app:tint="#000000" />

        <TextView
            android:id="@+id/textView177"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="138dp"
            android:text="@string/create_account"
            android:textColor="#000000"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvChildNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/child_1"
            android:textColor="#888888"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView177" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/glStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="32dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/glEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="32dp" />

        <!-- Avatar Section -->
        <LinearLayout
            android:id="@+id/llLabelPhoto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvChildNumber">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/child_s_photo"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/view46"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_avatar_circle"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelPhoto">

            <ImageView
                android:id="@+id/imageView39"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_person_placeholder"
                android:scaleType="centerCrop"
                android:contentDescription="@string/avatar"
                android:padding="2dp" />
        </FrameLayout>

        <Button
            android:id="@+id/btnSignup2AddPhoto"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/textfield_shape"
            android:backgroundTint="#FFFFFF"
            android:text="@string/add_photo"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/view46"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toEndOf="@+id/view46"
            app:layout_constraintTop_toTopOf="@+id/view46" />

        <ImageView
            android:id="@+id/imageView41"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/photo_camera"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            app:layout_constraintBottom_toBottomOf="@+id/btnSignup2AddPhoto"
            app:layout_constraintStart_toStartOf="@+id/btnSignup2AddPhoto"
            app:layout_constraintTop_toTopOf="@+id/btnSignup2AddPhoto" />

        <!-- First Name -->
        <LinearLayout
            android:id="@+id/llLabel1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/view46">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/child_s_first_name"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <EditText
            android:id="@+id/etChildFirstName"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_child_s_first_name"
            android:inputType="textPersonName"
            android:autofillHints="personGivenName"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabel1" />

        <TextView
            android:id="@+id/tvChildFirstNameWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/name_warning"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/etChildFirstName" />

        <!-- Last Name -->
        <LinearLayout
            android:id="@+id/llLabel2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvChildFirstNameWarning">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/child_s_last_name"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <EditText
            android:id="@+id/etChildLastName"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_child_s_last_name"
            android:inputType="textPersonName"
            android:autofillHints="personFamilyName"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabel2" />

        <TextView
            android:id="@+id/tvChildLastNameWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/name_warning"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/etChildLastName" />

        <!-- Middle Name & Suffix Row -->
        <LinearLayout
            android:id="@+id/llLabelMiddle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvChildLastNameWarning">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/middle_name"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/suffix"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/etChildMiddleName"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_child_s_middle"
            android:inputType="textPersonName"
            android:autofillHints="personMiddleName"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toStartOf="@+id/btnSignup2Suffix"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelMiddle" />

        <FrameLayout
            android:id="@+id/btnSignup2Suffix"
            android:layout_width="100dp"
            android:layout_height="40dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintTop_toTopOf="@+id/etChildMiddleName">

            <TextView
                android:id="@+id/tvSignup2SelectedSuffix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:text="@string/suffix"
                android:textColor="#888888"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="8dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_chevron_down"
                app:tint="#888888" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvChildMiddleNameWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/name_warning"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@+id/etChildMiddleName"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/etChildMiddleName" />

        <!-- Row: Age, Class, Grade Labels -->
        <LinearLayout
            android:id="@+id/llLabelRow3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvChildMiddleNameWarning">

            <!-- Age Label -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:baselineAligned="false">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/age"
                    android:textColor="#241E40"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/asterisk"
                    android:textColor="#FF0000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="2dp"
                    android:importantForAccessibility="no" />
            </LinearLayout>

            <!-- Class Label -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:layout_marginStart="8dp"
                android:orientation="horizontal"
                android:baselineAligned="false">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/class_label"
                    android:textColor="#241E40"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/asterisk"
                    android:textColor="#FF0000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="2dp"
                    android:importantForAccessibility="no" />
            </LinearLayout>

            <!-- Grade Label -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:layout_marginStart="8dp"
                android:orientation="horizontal"
                android:baselineAligned="false">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/grade"
                    android:textColor="#241E40"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/asterisk"
                    android:textColor="#FF0000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="2dp"
                    android:importantForAccessibility="no" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row: Age, Class, Grade Inputs -->
        <LinearLayout
            android:id="@+id/llInputRow3"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelRow3">

            <EditText
                android:id="@+id/etChildAge"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:hint="@string/age"
                android:inputType="number"
                android:autofillHints="none"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etChildClass"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:layout_marginStart="8dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:hint="@string/class_label"
                android:inputType="text"
                android:autofillHints="none"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textSize="14sp" />

            <FrameLayout
                android:id="@+id/btnSignup2Grade"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:layout_marginStart="8dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvSignup2SelectedGrade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="20dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/grade"
                    android:textColor="#888888"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_chevron_down"
                    app:tint="#888888" />
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvChildAgeWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llInputRow3" />

        <!-- Row: School -->
        <LinearLayout
            android:id="@+id/llLabelSchool"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvChildAgeWarning">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/school"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <EditText
            android:id="@+id/etSignup2School"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_child_s_school"
            android:inputType="text"
            android:autofillHints="none"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelSchool" />

        <!-- Pickup Address Section -->
        <LinearLayout
            android:id="@+id/llLabelPickup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/etSignup2School">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pickup_address"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <EditText
            android:id="@+id/etSignup2PickupAddress"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_pickup_address"
            android:inputType="textPostalAddress"
            android:autofillHints="postalAddress"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelPickup" />

        <!-- Map Section -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clMapContainer"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:layout_marginTop="12dp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/etSignup2PickupAddress">

            <org.osmdroid.views.MapView
                android:id="@+id/mapSignup2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#FAF6DB" />

            <ImageButton
                android:id="@+id/btnSignup2MyLocation"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="12dp"
                android:background="@drawable/circle_shape"
                android:backgroundTint="#FFFFFF"
                android:elevation="4dp"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_my_location"
                android:contentDescription="@string/my_location"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:tint="#666666" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <Button
            android:id="@+id/btnSignup2AddChild"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/textfield_shape"
            android:backgroundTint="#FFFFFF"
            android:text="@string/add_another_child"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/clMapContainer" />

        <!-- Navigation Buttons -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="32dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/btnSignup2AddChild">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignup2Back"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/back_caps"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="20dp"
                app:strokeColor="#000000"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignup2Next"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/next"
                android:textAllCaps="true"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="#FEBE1E"
                app:cornerRadius="20dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
