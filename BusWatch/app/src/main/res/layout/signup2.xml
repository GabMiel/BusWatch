<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="vertical"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- Top Header -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:contentDescription="@string/logo"
            android:src="@drawable/logo_with_bg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvBusWatch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/buswatch"
            android:textColor="#000000"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="@+id/ivLogo"
            app:layout_constraintStart_toEndOf="@+id/ivLogo"
            app:layout_constraintTop_toTopOf="@+id/ivLogo" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/glStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="32dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/glEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="32dp" />

        <!-- Progress Indicators -->
        <View
            android:id="@+id/viewParent"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginTop="79dp"
            android:layout_marginStart="24dp"
            android:background="@drawable/circle_shape"
            android:backgroundTint="#FEBE1E"
            app:layout_constraintEnd_toStartOf="@+id/viewChild"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivParent"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/user"
            app:layout_constraintBottom_toBottomOf="@+id/viewParent"
            app:layout_constraintEnd_toEndOf="@+id/viewParent"
            app:layout_constraintStart_toStartOf="@+id/viewParent"
            app:layout_constraintTop_toTopOf="@+id/viewParent"
            app:tint="#000000" />

        <TextView
            android:id="@+id/tvParentInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/parent_information_newline"
            android:textColor="#FEBE1E"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/viewParent"
            app:layout_constraintStart_toStartOf="@+id/viewParent"
            app:layout_constraintTop_toBottomOf="@+id/viewParent" />

        <View
            android:id="@+id/viewChild"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/circle_shape"
            android:backgroundTint="#FEBE1E"
            app:layout_constraintEnd_toStartOf="@+id/viewEmergency"
            app:layout_constraintStart_toEndOf="@+id/viewParent"
            app:layout_constraintTop_toTopOf="@+id/viewParent" />

        <ImageView
            android:id="@+id/ivChildren"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/child"
            app:layout_constraintBottom_toBottomOf="@+id/viewChild"
            app:layout_constraintEnd_toEndOf="@+id/viewChild"
            app:layout_constraintStart_toStartOf="@+id/viewChild"
            app:layout_constraintTop_toTopOf="@+id/viewChild"
            app:tint="#000000" />

        <TextView
            android:id="@+id/tvChildInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/child_information_newline"
            android:textColor="#FEBE1E"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/viewChild"
            app:layout_constraintStart_toStartOf="@+id/viewChild"
            app:layout_constraintTop_toBottomOf="@+id/viewChild" />

        <View
            android:id="@+id/viewEmergency"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/circle_shape"
            android:backgroundTint="#C4C4C4"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toEndOf="@+id/viewChild"
            app:layout_constraintTop_toTopOf="@+id/viewParent" />

        <ImageView
            android:id="@+id/ivEmergency"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/heart"
            app:layout_constraintBottom_toBottomOf="@+id/viewEmergency"
            app:layout_constraintEnd_toEndOf="@+id/viewEmergency"
            app:layout_constraintStart_toStartOf="@+id/viewEmergency"
            app:layout_constraintTop_toTopOf="@+id/viewEmergency"
            app:tint="#000000" />

        <TextView
            android:id="@+id/tvEmergencyInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/emergency"
            android:textColor="#C4C4C4"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/viewEmergency"
            app:layout_constraintStart_toStartOf="@+id/viewEmergency"
            app:layout_constraintTop_toBottomOf="@+id/viewEmergency" />

        <!-- Connecting Lines -->
        <View
            android:id="@+id/viewProgressLine1"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:background="#FEBE1E"
            app:layout_constraintBottom_toBottomOf="@+id/viewParent"
            app:layout_constraintEnd_toStartOf="@+id/viewChild"
            app:layout_constraintStart_toEndOf="@+id/viewParent"
            app:layout_constraintTop_toTopOf="@+id/viewParent" />

        <View
            android:id="@+id/viewProgressLine2"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:background="#C4C4C4"
            app:layout_constraintBottom_toBottomOf="@+id/viewChild"
            app:layout_constraintEnd_toStartOf="@+id/viewEmergency"
            app:layout_constraintStart_toEndOf="@+id/viewChild"
            app:layout_constraintTop_toTopOf="@+id/viewChild" />

        <!-- Form Title -->
        <TextView
            android:id="@+id/tvCreateAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/create_account"
            android:textColor="#000000"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvChildInfo" />

        <TextView
            android:id="@+id/tvChildNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/child_1"
            android:textColor="#888888"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvCreateAccount" />

        <!-- Avatar Section -->
        <LinearLayout
            android:id="@+id/llLabelPhoto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvChildNumber">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/child_s_photo"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/view46"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_avatar_circle"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelPhoto">

            <ImageView
                android:id="@+id/imageView39"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_person_placeholder"
                android:scaleType="centerCrop"
                android:contentDescription="@string/avatar"
                android:padding="2dp" />
        </FrameLayout>

        <Button
            android:id="@+id/btnSignup2AddPhoto"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/textfield_shape"
            android:backgroundTint="#FFFFFF"
            android:text="@string/add_photo"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/view46"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toEndOf="@+id/view46"
            app:layout_constraintTop_toTopOf="@+id/view46" />

        <ImageView
            android:id="@+id/imageView41"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/photo_camera"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            app:layout_constraintBottom_toBottomOf="@+id/btnSignup2AddPhoto"
            app:layout_constraintStart_toStartOf="@+id/btnSignup2AddPhoto"
            app:layout_constraintTop_toTopOf="@+id/btnSignup2AddPhoto" />

        <!-- First Name -->
        <LinearLayout
            android:id="@+id/llLabel1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/view46">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/child_s_first_name"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/etChildFirstName"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_child_s_first_name"
            android:inputType="textPersonName"
            android:autofillHints="personGivenName"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabel1" />

        <TextView
            android:id="@+id/tvChildFirstNameWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/name_warning"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/etChildFirstName" />

        <!-- Last Name -->
        <LinearLayout
            android:id="@+id/llLabel2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvChildFirstNameWarning">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/child_s_last_name"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/etChildLastName"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_child_s_last_name"
            android:inputType="textPersonName"
            android:autofillHints="personFamilyName"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabel2" />

        <TextView
            android:id="@+id/tvChildLastNameWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/name_warning"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/etChildLastName" />

        <!-- Middle Name & Suffix -->
        <LinearLayout
            android:id="@+id/llLabelMiddle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvChildLastNameWarning">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/middle_name"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/suffix"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/etChildMiddleName"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_child_s_middle"
            android:inputType="textPersonName"
            android:autofillHints="personMiddleName"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toStartOf="@+id/btnSignup2Suffix"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelMiddle" />

        <FrameLayout
            android:id="@+id/btnSignup2Suffix"
            android:layout_width="100dp"
            android:layout_height="40dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintTop_toTopOf="@+id/etChildMiddleName">
            <TextView
                android:id="@+id/tvSignup2SelectedSuffix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:text="@string/suffix"
                android:textColor="#888888"
                android:textSize="14sp" />
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_chevron_down"
                android:contentDescription="@null"
                app:tint="#888888" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvChildMiddleNameWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/name_warning"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/etChildMiddleName" />

        <!-- Age, Grade, Section Row -->
        <LinearLayout
            android:id="@+id/llLabelRow3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvChildMiddleNameWarning">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:orientation="horizontal"
                android:baselineAligned="false">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/age"
                    android:textColor="#241E40"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/asterisk"
                    android:textColor="#FF0000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:layout_marginStart="8dp"
                android:orientation="horizontal"
                android:baselineAligned="false">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/grade"
                    android:textColor="#241E40"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/asterisk"
                    android:textColor="#FF0000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="horizontal"
                android:baselineAligned="false">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_grade"
                    android:textColor="#241E40"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/asterisk"
                    android:textColor="#FF0000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="2dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llInputRow3"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelRow3">

            <EditText
                android:id="@+id/etChildAge"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.8"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:hint="@string/age"
                android:inputType="number"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textSize="14sp"
                android:autofillHints="none" />

            <FrameLayout
                android:id="@+id/btnSignup2Grade"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:layout_marginStart="8dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvSignup2SelectedGrade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    android:text="@string/select_grade"
                    android:textColor="#888888"
                    android:textSize="14sp" />
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="4dp"
                    android:src="@drawable/ic_chevron_down"
                    android:contentDescription="@null"
                    app:tint="#888888" />
            </FrameLayout>

            <EditText
                android:id="@+id/etChildSection"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:hint="@string/section_grade"
                android:inputType="text"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textSize="14sp"
                android:autofillHints="none" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvChildAgeWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llInputRow3" />

        <!-- School -->
        <LinearLayout
            android:id="@+id/llLabelSchool"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvChildAgeWarning">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/school"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/etSignup2School"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_child_s_school"
            android:inputType="text"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelSchool"
            android:autofillHints="none" />

        <!-- Home Address Section -->
        <LinearLayout
            android:id="@+id/llLabelHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/etSignup2School">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_address"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asterisk"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="2dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/etSignup2HomeAddress"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_home_address"
            android:inputType="textPostalAddress"
            android:autofillHints="postalAddress"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelHome" />

        <!-- Map Section -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clMapContainer"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:layout_marginTop="24dp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/etSignup2HomeAddress">
            <org.osmdroid.views.MapView
                android:id="@+id/mapSignup2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#FAF6DB" />

            <ImageButton
                android:id="@+id/btnSignup2MyLocation"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="12dp"
                android:background="@drawable/circle_shape"
                android:backgroundTint="#FFFFFF"
                android:elevation="4dp"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_my_location"
                android:contentDescription="@string/my_location"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:tint="#666666" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Medical Information Section -->
        <TextView
            android:id="@+id/tvMedicalInfoHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/medical_information"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/clMapContainer"
            android:layout_marginTop="24dp" />

        <!-- Blood Type -->
        <TextView
            android:id="@+id/llLabelBloodType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/blood_type_optional"
            android:textColor="#241E40"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvMedicalInfoHeader" />

        <FrameLayout
            android:id="@+id/btnSignup2BloodType"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelBloodType">

            <TextView
                android:id="@+id/tvSignup2SelectedBloodType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:text="@string/select_blood_type"
                android:textColor="#888888"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_chevron_down"
                android:contentDescription="@null"
                app:tint="#888888" />
        </FrameLayout>

        <TextView
            android:id="@+id/llLabelAllergies"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/allergies_optional"
            android:textColor="#241E40"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/btnSignup2BloodType" />

        <EditText
            android:id="@+id/etChildAllergies"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_child_allergies"
            android:inputType="text"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:textSize="14sp"
            android:autofillHints="none"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelAllergies" />

        <TextView
            android:id="@+id/llLabelMedications"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/current_medications_optional"
            android:textColor="#241E40"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/etChildAllergies" />

        <EditText
            android:id="@+id/etChildMedications"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_child_medications"
            android:inputType="text"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:textSize="14sp"
            android:autofillHints="none"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelMedications" />

        <TextView
            android:id="@+id/llLabelConditions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/medical_conditions_optional"
            android:textColor="#241E40"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/etChildMedications" />

        <EditText
            android:id="@+id/etChildConditions"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:hint="@string/enter_child_medical_conditions"
            android:inputType="text"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:textSize="14sp"
            android:autofillHints="none"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llLabelConditions"
            tools:ignore="TextFields" />

        <Button
            android:id="@+id/btnSignup2AddChild"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/textfield_shape"
            android:backgroundTint="#FFFFFF"
            android:text="@string/add_another_child"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/etChildConditions" />

        <!-- Navigation Buttons -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="32dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/btnSignup2AddChild">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignup2Back"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/back_caps"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="20dp"
                app:strokeColor="#000000"
                app:strokeWidth="1dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignup2Next"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/next_caps"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="#FEBE1E"
                app:cornerRadius="20dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>