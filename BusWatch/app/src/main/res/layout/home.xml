        app:layout_constraintStart_toStartOf="@+id/textView90"
        app:layout_constraintTop_toBottomOf="@+id/textView90" />

    <!-- Box 1 Content -->
    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="59dp"
