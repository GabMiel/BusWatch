<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/imageView33"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:contentDescription="@string/logo"
            android:src="@drawable/logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/textView172"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/buswatch"
            android:textColor="#000000"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="@+id/imageView33"
            app:layout_constraintStart_toEndOf="@+id/imageView33"
            app:layout_constraintTop_toTopOf="@+id/imageView33"
            android:layout_marginStart="8dp" />

        <!-- Progress Indicators consistent with signup1 and signup2 -->
        <View
            android:id="@+id/view39"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/circle_shape"
            android:backgroundTint="#FEBE1E"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="28dp"
            android:layout_marginTop="79dp" />

        <TextView
            android:id="@+id/textView173"
            android:layout_width="79dp"
            android:layout_height="34dp"
            android:text="@string/parent_information"
            android:textColor="#FEBE1E"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/view39"
            app:layout_constraintTop_toTopOf="@+id/view39"
            android:layout_marginStart="8dp" />

        <View
            android:id="@+id/view40"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/circle_shape"
            android:backgroundTint="#FEBE1E"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="149dp"
            android:layout_marginTop="79dp" />

        <TextView
            android:id="@+id/textView174"
            android:layout_width="79dp"
            android:layout_height="34dp"
            android:text="@string/child_information"
            android:textColor="#FEBE1E"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/view40"
            app:layout_constraintTop_toTopOf="@+id/view40"
            android:layout_marginStart="8dp" />

        <View
            android:id="@+id/view45"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/circle_shape"
            android:backgroundTint="#FEBE1E"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="268dp"
            android:layout_marginTop="79dp" />

        <TextView
            android:id="@+id/textView175"
            android:layout_width="79dp"
            android:layout_height="34dp"
            android:text="@string/medical_information"
            android:textColor="#FEBE1E"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/view45"
            app:layout_constraintTop_toTopOf="@+id/view45"
            android:layout_marginStart="8dp" />

        <ImageView
            android:id="@+id/imageView35"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@string/user_icon"
            android:src="@drawable/user"
            app:layout_constraintBottom_toBottomOf="@+id/view39"
            app:layout_constraintEnd_toEndOf="@+id/view39"
            app:layout_constraintStart_toStartOf="@+id/view39"
            app:layout_constraintTop_toTopOf="@+id/view39" />

        <ImageView
            android:id="@+id/imageView38"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@string/child_icon"
            android:src="@drawable/child"
            app:layout_constraintBottom_toBottomOf="@+id/view40"
            app:layout_constraintEnd_toEndOf="@+id/view40"
            app:layout_constraintStart_toStartOf="@+id/view40"
            app:layout_constraintTop_toTopOf="@+id/view40" />

        <ImageView
            android:id="@+id/imageView36"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@string/medical_icon"
            android:src="@drawable/heart"
            app:layout_constraintBottom_toBottomOf="@+id/view45"
            app:layout_constraintEnd_toEndOf="@+id/view45"
            app:layout_constraintStart_toStartOf="@+id/view45"
            app:layout_constraintTop_toTopOf="@+id/view45" />

        <TextView
            android:id="@+id/textView177"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_account"
            android:textColor="#000000"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="138dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/glStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="32dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/glEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="32dp" />

        <TextView
            android:id="@+id/textView196"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/medical_information"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/textView177"
            android:layout_marginTop="48dp" />

        <!-- Blood Type -->
        <LinearLayout
            android:id="@+id/llBloodType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/textView196">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/blood_type_optional"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/editTextText2"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="@drawable/textfield_shape"
            android:backgroundTint="#D1D1D1"
            android:hint="@string/select_blood_type"
            android:inputType="text"
            android:autofillHints="none"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llBloodType"
            android:layout_marginTop="4dp" />

        <!-- Allergies -->
        <LinearLayout
            android:id="@+id/llAllergies"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/editTextText2">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/allergies_optional"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/editTextText13"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="@drawable/textfield_shape"
            android:backgroundTint="#D1D1D1"
            android:hint="@string/e_g_peanuts_shellfish_none"
            android:inputType="text"
            android:autofillHints="none"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llAllergies"
            android:layout_marginTop="4dp" />

        <!-- Current Medications -->
        <LinearLayout
            android:id="@+id/llMedications"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/editTextText13">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/current_medications_optional"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/editTextText14"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="@drawable/textfield_shape"
            android:backgroundTint="#D1D1D1"
            android:hint="@string/e_g_inhaler_epipen_none"
            android:inputType="text"
            android:autofillHints="none"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llMedications"
            android:layout_marginTop="4dp" />

        <!-- Medical Conditions -->
        <LinearLayout
            android:id="@+id/llConditions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/editTextText14">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/medical_conditions_optional"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/editTextText15"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="@drawable/textfield_shape"
            android:backgroundTint="#D1D1D1"
            android:hint="@string/e_g_asthma_diabetes_none"
            android:inputType="text"
            android:autofillHints="none"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llConditions"
            android:layout_marginTop="4dp" />

        <!-- Emergency Contact 1 -->
        <LinearLayout
            android:id="@+id/llEmergency1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/editTextText15">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/emergency_contact_1"
                android:textColor="#241E40"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvLabelName1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/contact_name"
            android:textColor="#241E40"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llEmergency1"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/editTextText17"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="@drawable/textfield_shape"
            android:backgroundTint="#D1D1D1"
            android:hint="@string/enter_contact_name"
            android:inputType="textPersonName"
            android:autofillHints="personName"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvLabelName1"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvLabelPhone1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/contact_phone"
            android:textColor="#241E40"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/editTextText17"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/editTextText18"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="@drawable/textfield_shape"
            android:backgroundTint="#D1D1D1"
            android:hint="@string/enter_contact_phone"
            android:inputType="phone"
            android:autofillHints="phoneNumber"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvLabelPhone1"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvLabelRel1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/relationship"
            android:textColor="#241E40"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/editTextText18"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/editTextText19"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="@drawable/textfield_shape"
            android:backgroundTint="#D1D1D1"
            android:hint="@string/e_g_mother_father_guardian"
            android:inputType="text"
            android:autofillHints="none"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvLabelRel1"
            android:layout_marginTop="4dp" />

        <!-- Emergency Contact 2 -->
        <LinearLayout
            android:id="@+id/llEmergency2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/editTextText19">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/emergency_contact_2_optional"
                android:textColor="#241E40"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvLabelName2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/contact_name"
            android:textColor="#241E40"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/llEmergency2"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/editTextText20"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="@drawable/textfield_shape"
            android:backgroundTint="#D1D1D1"
            android:hint="@string/enter_contact_name"
            android:inputType="textPersonName"
            android:autofillHints="personName"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvLabelName2"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvLabelPhone2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/contact_phone"
            android:textColor="#241E40"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/editTextText20"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/editTextText22"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="@drawable/textfield_shape"
            android:backgroundTint="#D1D1D1"
            android:hint="@string/enter_contact_phone"
            android:inputType="phone"
            android:autofillHints="phoneNumber"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvLabelPhone2"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvLabelRel2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/relationship"
            android:textColor="#241E40"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/editTextText22"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/editTextText21"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="@drawable/textfield_shape"
            android:backgroundTint="#D1D1D1"
            android:hint="@string/e_g_mother_father_guardian"
            android:inputType="text"
            android:autofillHints="none"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/tvLabelRel2"
            android:layout_marginTop="4dp" />

        <!-- Navigation Buttons -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="32dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/glEnd"
            app:layout_constraintStart_toStartOf="@+id/glStart"
            app:layout_constraintTop_toBottomOf="@+id/editTextText21">

            <Button
                android:id="@+id/btnSignup3Back"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/soft_corner"
                android:backgroundTint="#FFFFFF"
                android:text="@string/back"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                app:strokeColor="#000000"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/btnSignup3Register"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/soft_corner"
                android:backgroundTint="#000000"
                android:text="@string/register"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
