<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Header Section -->
    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/dark_header"
        android:paddingHorizontal="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBusBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back_button"
            android:src="@drawable/ic_back"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@id/btnBusBack"
            android:text="@string/bus_details"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Bus Information Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_details_card"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:text="@string/bus_information"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02" />

                <!-- Bus Number Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/bus_number" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                        tools:ignore="SmallSp" />
                    <TextView
                        android:id="@+id/valBusNo"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/rectangle_hollow_with_shadow"
                        android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                        android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
                </LinearLayout>

                <!-- Status and Capacity -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="16dp"
                    android:baselineAligned="false">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginEnd="8dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/status" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                            tools:ignore="SmallSp" />
                        <TextView android:id="@+id/valStatus"
                            android:layout_width="match_parent" android:layout_height="48dp"
                            android:background="@drawable/rectangle_hollow_with_shadow"
                            android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                            android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/capacity" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                            tools:ignore="SmallSp" />
                        <TextView android:id="@+id/valCap"
                            android:layout_width="match_parent" android:layout_height="48dp"
                            android:background="@drawable/rectangle_hollow_with_shadow"
                            android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                            android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Students and Seats -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginEnd="8dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/total_of_students" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                            tools:ignore="SmallSp" />
                        <TextView android:id="@+id/valTotalStuds"
                            android:layout_width="match_parent" android:layout_height="48dp"
                            android:background="@drawable/rectangle_hollow_with_shadow"
                            android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                            android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/available_seats" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                            tools:ignore="SmallSp" />
                        <TextView android:id="@+id/valSeats"
                            android:layout_width="match_parent" android:layout_height="48dp"
                            android:background="@drawable/rectangle_hollow_with_shadow"
                            android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                            android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Driver Information Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_details_card"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:text="@string/driver_information"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02" />

                <!-- Driver Name Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Driver Name" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                        tools:ignore="SmallSp,HardcodedText" />
                    <TextView
                        android:id="@+id/valName"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/rectangle_hollow_with_shadow"
                        android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                        android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
                </LinearLayout>

                <!-- Phone Number Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/phone_label" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                        tools:ignore="SmallSp" />
                    <TextView
                        android:id="@+id/tvDriverPhone"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/rectangle_hollow_with_shadow"
                        android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                        android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
                </LinearLayout>

                <!-- Email Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/email" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                        tools:ignore="SmallSp" />
                    <TextView
                        android:id="@+id/tvDriverEmail"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/rectangle_hollow_with_shadow"
                        android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                        android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
                </LinearLayout>

                <!-- License Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/license_number" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                        tools:ignore="SmallSp" />
                    <TextView
                        android:id="@+id/tvDriverLicense"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/rectangle_hollow_with_shadow"
                        android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                        android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/btnBackAction"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="32dp"
                android:text="BACK"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:clickable="true"
                android:focusable="true"
                tools:ignore="HardcodedText" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
