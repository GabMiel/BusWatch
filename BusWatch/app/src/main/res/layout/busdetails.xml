<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_light">

    <!-- Header Section -->
    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/dark_header"
        android:paddingHorizontal="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBusBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back_button"
            android:src="@drawable/ic_back"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            style="@style/TopBarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@id/btnBusBack"
            android:text="@string/bus_details_caps"
            android:textColor="@color/white" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Bus Information Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_details_card"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="24dp">

                <TextView
                    style="@style/SectionHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="@string/bus_information"
                    android:textAllCaps="true" />

                <!-- Bus Number Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView style="@style/DetailsLabel" android:text="@string/bus_number" />
                    <TextView
                        android:id="@+id/valBusNo"
                        style="@style/DetailsValue"
                        android:text="@string/placeholder_hyphen"/>
                </LinearLayout>

                <!-- Vehicle Type and Capacity Row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:baselineAligned="false">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginEnd="8dp" android:orientation="vertical">
                        <TextView style="@style/DetailsLabel" android:text="@string/vehicle_type" />
                        <TextView android:id="@+id/valVehicleType"
                            style="@style/DetailsValue"
                            android:text="@string/placeholder_hyphen"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="0.8" android:orientation="vertical">
                        <TextView style="@style/DetailsLabel" android:text="@string/capacity" />
                        <TextView android:id="@+id/valCap"
                            style="@style/DetailsValue"
                            android:text="@string/placeholder_hyphen"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Status and Plate Number Row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginEnd="8dp" android:orientation="vertical">
                        <TextView style="@style/DetailsLabel" android:text="@string/status" />
                        <TextView android:id="@+id/valStatus"
                            style="@style/DetailsValue"
                            android:text="@string/placeholder_hyphen"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView style="@style/DetailsLabel" android:text="@string/plate_number_label" />
                        <TextView android:id="@+id/valPlateNumber"
                            style="@style/DetailsValue"
                            android:text="@string/placeholder_hyphen"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Schedule Information Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_details_card"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="24dp">

                <TextView
                    style="@style/SectionHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="@string/schedule_information"
                    android:textAllCaps="true" />

                <!-- Morning Schedule Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView style="@style/DetailsLabel" android:text="@string/morning_schedule" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:id="@+id/tvMorningStart"
                            style="@style/DetailsValue"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/start_time"
                            android:layout_marginEnd="4dp" />
                        <TextView android:id="@+id/tvMorningEnd"
                            style="@style/DetailsValue"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/end_time"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Afternoon Schedule Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView style="@style/DetailsLabel" android:text="@string/afternoon_schedule" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:id="@+id/tvAfternoonStart"
                            style="@style/DetailsValue"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/start_time"
                            android:layout_marginEnd="4dp" />
                        <TextView android:id="@+id/tvAfternoonEnd"
                            style="@style/DetailsValue"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/end_time"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Driver Information Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_details_card"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="32dp">

                <TextView
                    style="@style/SectionHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="@string/driver_information"
                    android:textAllCaps="true" />

                <!-- Driver Avatar -->
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="24dp">
                    <ImageView
                        android:id="@+id/ivDriverPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_person_placeholder"
                        android:background="@drawable/bg_avatar_circle"
                        android:scaleType="centerCrop"
                        android:padding="2dp"
                        android:contentDescription="@string/avatar" />
                </FrameLayout>

                <!-- Row 1: Name and Phone -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp" android:orientation="vertical">
                        <TextView style="@style/DetailsLabel" android:text="@string/driver_name" />
                        <TextView
                            android:id="@+id/valName"
                            style="@style/DetailsValue"
                            android:text="@string/placeholder_hyphen"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView style="@style/DetailsLabel" android:text="@string/phone_label" />
                        <TextView
                            android:id="@+id/tvDriverPhone"
                            style="@style/DetailsValue"
                            android:text="@string/placeholder_hyphen"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Row 2: Email and License -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp" android:orientation="vertical">
                        <TextView style="@style/DetailsLabel" android:text="@string/email" />
                        <TextView
                            android:id="@+id/tvDriverEmail"
                            style="@style/DetailsValue"
                            android:text="@string/placeholder_hyphen"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView style="@style/DetailsLabel" android:text="@string/license_number_label" />
                        <TextView
                            android:id="@+id/tvDriverLicense"
                            style="@style/DetailsValue"
                            android:text="@string/placeholder_hyphen"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
