<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_details_card"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvEditStudentTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/student_details"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnDismissEditGeneral"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="-12dp"
        android:layout_marginTop="-12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/close"
        android:padding="14dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#666666" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvStudentFields"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fillViewport="true"
        app:layout_constrainedHeight="true"
        app:layout_constraintBottom_toTopOf="@+id/llStudentActions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_max="450dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvEditStudentTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Student Picture -->
            <RelativeLayout
                android:id="@+id/rlEditStudentAvatar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:id="@+id/viewAvatarBg"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_centerHorizontal="true"
                    android:background="@drawable/bg_avatar_circle">

                    <ImageView
                        android:id="@+id/imgEditStudentAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/avatar"
                        android:padding="2dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user" />
                </FrameLayout>

                <ImageButton
                    android:id="@+id/btnChangeAvatar"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_alignEnd="@id/viewAvatarBg"
                    android:layout_alignBottom="@id/viewAvatarBg"
                    android:background="@drawable/circle_shape"
                    android:backgroundTint="#FEBE1E"
                    android:elevation="4dp"
                    android:padding="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/photo_camera"
                    app:tint="#000000"
                    android:contentDescription="@string/edit"
                    android:clickable="false" />
            </RelativeLayout>

            <!-- Student ID -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/student_id"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etEditStudentId"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:hint="@string/student_id"
                android:inputType="text"
                android:autofillHints="none"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:textColorHint="@color/gray_text" />

            <!-- First Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/first_name"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etEditFirstName"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:hint="@string/first_name"
                android:inputType="textPersonName"
                android:autofillHints="personGivenName"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:textColorHint="@color/gray_text" />

            <!-- Last Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/last_name"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etEditLastName"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:hint="@string/last_name"
                android:inputType="textPersonName"
                android:autofillHints="personFamilyName"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:textColorHint="@color/gray_text" />

            <!-- Middle Name and Suffix Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/middle_name"
                        android:textColor="#241E40"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/etEditMiddleName"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/rectangle_hollow_with_shadow"
                        android:hint="@string/middle_name"
                        android:inputType="textPersonName"
                        android:autofillHints="personMiddleName"
                        android:paddingHorizontal="12dp"
                        android:textSize="14sp"
                        android:textColorHint="@color/gray_text" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/suffix"
                        android:textColor="#241E40"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <FrameLayout
                        android:id="@+id/btnEditStudentSuffix"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/rectangle_hollow_with_shadow"
                        android:clickable="true" android:focusable="true">

                        <TextView
                            android:id="@+id/tvEditStudentSelectedSuffix"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="12dp"
                            android:text="@string/suffix"
                            android:textColor="#888888"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center_vertical|end"
                            android:layout_marginEnd="8dp"
                            android:contentDescription="@string/suffix"
                            android:src="@drawable/ic_chevron_down"
                            app:tint="#888888" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Age, Section, Grade Row Labels -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/age"
                    android:textColor="#241E40"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:layout_marginStart="8dp"
                    android:text="@string/section_label"
                    android:textColor="#241E40"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:layout_marginStart="8dp"
                    android:text="@string/grade"
                    android:textColor="#241E40"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Age, Section, Grade Inputs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etEditDob"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:hint="@string/age"
                    android:inputType="number"
                    android:autofillHints="none"
                    android:paddingHorizontal="8dp"
                    android:textSize="14sp"
                    android:textColorHint="@color/gray_text" />

                <EditText
                    android:id="@+id/etEditSection"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.2"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:hint="@string/section_label"
                    android:inputType="text"
                    android:autofillHints="none"
                    android:paddingHorizontal="8dp"
                    android:textSize="14sp"
                    android:textColorHint="@color/gray_text" />

                <FrameLayout
                    android:id="@+id/btnEditGrade"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.2"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:clickable="true" android:focusable="true">

                    <TextView
                        android:id="@+id/tvEditSelectedGrade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="20dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/grade"
                        android:textColor="#888888"
                        android:textSize="14sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="4dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_down"
                        app:tint="#888888" />
                </FrameLayout>
            </LinearLayout>

            <!-- School -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/school"
                android:textColor="#241E40"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etEditSchool"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:hint="@string/school"
                android:inputType="text"
                android:autofillHints="none"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:textColorHint="@color/gray_text" />

            <!-- Home Address Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_address"
                    android:textColor="#241E40"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRequestAddressEdit"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="@string/change_pickup_location"
                    android:textSize="11sp"
                    android:textColor="#000000"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingHorizontal="12dp"
                    app:backgroundTint="#FEBE1E"
                    app:cornerRadius="16dp" />
            </LinearLayout>

            <EditText
                android:id="@+id/etEditAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="45dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:gravity="center_vertical"
                android:hint="@string/home_address"
                android:inputType="textPostalAddress"
                android:autofillHints="postalAddress"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:textSize="14sp"
                android:enabled="false"
                android:textColorHint="@color/gray_text" />

            <!-- Pickup Stop Section -->
            <LinearLayout
                android:id="@+id/layoutEditStopHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pickup Stop"
                    android:textColor="#241E40"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditChangeStop"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="CHANGE STOP"
                    android:textSize="11sp"
                    android:textColor="#000000"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingHorizontal="12dp"
                    app:backgroundTint="#FEBE1E"
                    app:cornerRadius="16dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvEditAssignedStop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="45dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="Not Selected"
                android:textColor="#888888"
                android:textSize="14sp"
                android:clickable="false"
                android:focusable="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Action Buttons -->
    <LinearLayout
        android:id="@+id/llStudentActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nsvStudentFields">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelEdit"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/cancel_caps"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="20dp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveStudent"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="@string/save_caps"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="#FEBE1E"
            app:cornerRadius="20dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
