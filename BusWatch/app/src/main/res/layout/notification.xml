<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header Section -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="0dp"
        android:layout_height="75dp"
        android:background="#2D2D2D"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Normal Header Views -->
    <ImageButton
        android:id="@+id/btnNotificationBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back_button"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:src="@drawable/arrow"
        app:layout_constraintBottom_toBottomOf="@+id/headerBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/headerBg"
        app:tint="#FFFFFF" />

    <TextView
        android:id="@+id/tvNotificationTitleHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/notifications"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/headerBg"
        app:layout_constraintEnd_toStartOf="@+id/btnMarkAllRead"
        app:layout_constraintStart_toEndOf="@+id/btnNotificationBack"
        app:layout_constraintTop_toTopOf="@+id/headerBg" />

    <ImageButton
        android:id="@+id/btnMarkAllRead"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/mark_all_read"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_check"
        app:layout_constraintBottom_toBottomOf="@+id/headerBg"
        app:layout_constraintEnd_toStartOf="@+id/btnClearNotifications"
        app:layout_constraintTop_toTopOf="@+id/headerBg"
        app:tint="#FEBE1E" />

    <ImageButton
        android:id="@+id/btnClearNotifications"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/clear_all"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_delete"
        app:layout_constraintBottom_toBottomOf="@+id/headerBg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/headerBg"
        app:tint="#FFFFFF" />

    <!-- Selection Mode Header Views -->
    <ImageButton
        android:id="@+id/btnCancelSelection"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/cancel"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:src="@drawable/arrow"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/headerBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/headerBg"
        app:tint="#FFFFFF" />

    <TextView
        android:id="@+id/tvSelectedCount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/headerBg"
        app:layout_constraintEnd_toStartOf="@+id/btnSelectAll"
        app:layout_constraintStart_toEndOf="@id/btnCancelSelection"
        app:layout_constraintTop_toTopOf="@+id/headerBg"
        tools:text="0 selected"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/btnSelectAll"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:paddingHorizontal="12dp"
        android:text="@string/select_all"
        android:textColor="#FEBE1E"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/headerBg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/headerBg"
        tools:visibility="visible" />

    <!-- Filter Tabs -->
    <LinearLayout
        android:id="@+id/filterLayout"
        android:layout_width="0dp"
        android:layout_height="45dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/rectangle_hollow"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBg">

        <Button
            android:id="@+id/btnNotificationAll"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/rectangle_shape"
            android:backgroundTint="#FEBE1E"
            android:text="@string/all"
            android:textAllCaps="false"
            android:textColor="#000000"
            android:textSize="11sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnNotificationUnread"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="@string/unread"
            android:textAllCaps="false"
            android:textColor="#666666"
            android:textSize="11sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnNotificationRead"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="@string/read"
            android:textAllCaps="false"
            android:textColor="#666666"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Fragment Container for List -->
    <FrameLayout
        android:id="@+id/notificationListContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottomDeleteBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filterLayout" />

    <!-- Bottom Delete Bar (Hidden by default) -->
    <LinearLayout
        android:id="@+id/bottomDeleteBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F8F8F8"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:visibility="visible">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteSelected"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:backgroundTint="#FF4D4D"
            android:text="@string/delete"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <!-- Visibility Groups (Placed at end to override children) -->
    <androidx.constraintlayout.widget.Group
        android:id="@+id/groupNormalHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:constraint_referenced_ids="btnNotificationBack,tvNotificationTitleHeader,btnMarkAllRead,btnClearNotifications" />

    <androidx.constraintlayout.widget.Group
        android:id="@+id/groupSelectionHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:constraint_referenced_ids="btnCancelSelection,tvSelectedCount,btnSelectAll" />

</androidx.constraintlayout.widget.ConstraintLayout>