<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvDeleteTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/delete_account_warning"
        android:textColor="#FF4B4B"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDeleteTimerMsg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/delete_account_confirmation_msg"
        android:textColor="#333333"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etDeleteConfirm"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/rectangle_hollow_with_shadow"
        android:hint="@string/type_delete_to_confirm"
        android:importantForAutofill="no"
        android:inputType="textCapCharacters"
        android:paddingHorizontal="12dp"
        android:textSize="14sp" />

</LinearLayout>
