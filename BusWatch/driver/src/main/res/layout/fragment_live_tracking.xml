<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yellow_primary">

    <!-- Map placeholder (top half) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Map view placeholder — gray map bg -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#D8E0E8"/>

        <!-- Map texture lines (visual only) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/map_icon_emoji"
            android:textSize="72sp"
            android:contentDescription="@string/todo"/>

        <!-- ETA Badge -->
        <TextView
            android:id="@+id/tvETA"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="16dp"
            android:text="@string/eta_10_mins"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/bg_eta_badge"/>
    </FrameLayout>

    <!-- Bottom sheet — yellow bg -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/yellow_primary"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pick_up_student"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed-medium"
            android:layout_marginBottom="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPickup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>

    <!-- End Trip button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:background="@color/yellow_primary">
        <TextView
            android:id="@+id/btnEndTrip"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="@string/end_trip"
            android:textColor="@color/black"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="center"
            android:fontFamily="sans-serif-condensed-medium"
            android:background="@drawable/bg_end_trip"/>
    </LinearLayout>

</LinearLayout>
