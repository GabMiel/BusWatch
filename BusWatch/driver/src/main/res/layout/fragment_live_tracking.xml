<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- 1. Header Section (Fixed at top) -->
    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/dark_header"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btnBackTracking"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back_button"
            android:src="@drawable/ic_back"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@id/btnBackTracking"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvLiveTrackingTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="LIVE TRIP: ROUTE A" />

            <TextView
                android:id="@+id/tvBusIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_white_secondary"
                android:textSize="11sp"
                tools:text="Bus: BUS-001" />
        </LinearLayout>
    </RelativeLayout>

    <!-- 2. Next Stop Banner -->
    <LinearLayout
        android:id="@+id/bannerNextStop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/yellow_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="@string/bus_icon"
            android:src="@drawable/ic_bus"
            app:tint="@color/black" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRouteInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ASSIGNED ROUTE"
                android:textColor="@color/black"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNextStopName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:text="Main Entrance Gate" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvETA"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_eta_badge"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="10 MINS" />
    </LinearLayout>

    <!-- 3. Map Area (Takes up flexible space) -->
    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <org.osmdroid.views.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Maximize Button -->
        <ImageButton
            android:id="@+id/btnMaximizeMap"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:background="@drawable/circle_shape"
            android:backgroundTint="#CCFFFFFF"
            android:contentDescription="Maximize Map"
            android:elevation="4dp"
            android:padding="10dp"
            android:src="@drawable/ic_eye"
            app:tint="@color/black" />

        <!-- Locator Button -->
        <ImageButton
            android:id="@+id/btnMyLocation"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:background="@drawable/circle_shape"
            android:backgroundTint="#CCFFFFFF"
            android:contentDescription="Locate Stops"
            android:elevation="4dp"
            android:padding="10dp"
            android:src="@drawable/ic_my_location"
            app:tint="@color/black" />
    </FrameLayout>

    <!-- 4. Bottom Roster & Actions Section -->
    <LinearLayout
        android:id="@+id/layoutBottomInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/yellow_primary"
        android:orientation="vertical"
        android:paddingBottom="16dp"
        android:elevation="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingVertical="14dp">

            <TextView
                android:id="@+id/tvRosterTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/student_roster_caps"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBoardingCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="0 / 40 On Board" />
        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPickup"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:paddingHorizontal="12dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_pickup_row"
            tools:itemCount="2" />

        <TextView
            android:id="@+id/btnEndTrip"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_end_trip"
            android:gravity="center"
            android:text="@string/end_trip"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

</LinearLayout>
