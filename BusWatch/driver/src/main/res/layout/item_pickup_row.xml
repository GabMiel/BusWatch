<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/pickupRowContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_student_row">

    <ImageView
        android:id="@+id/imgPickupStudent"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_person_placeholder"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_avatar_circle"
        android:contentDescription="@string/avatar"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPickupName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/justin_wilson"
            android:textColor="@color/text_dark"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvStudentGrade"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/gray_text"
            android:textSize="11sp"
            tools:text="150 meters away"/>

        <TextView
            android:id="@+id/tvStopLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/gray_text"
            android:textSize="11sp"
            android:textStyle="italic"
            tools:text="Stop: Central Park"/>
    </LinearLayout>

    <TextView
        android:id="@+id/btnPickUp"
        android:layout_width="70dp"
        android:layout_height="30dp"
        android:text="@string/pick_up"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/bg_pickup_btn"
        android:clickable="true"
        android:focusable="true"/>
</LinearLayout>
