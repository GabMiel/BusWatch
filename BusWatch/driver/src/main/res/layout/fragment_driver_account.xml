<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Dark Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/dark_header"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBackAccount"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:contentDescription="@string/back_button"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/driver_details"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed-medium"/>
            <TextView
                android:id="@+id/tvDriverSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/robert_wilson_name"
                android:textColor="#AAAAAA"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Profile Information Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_cream"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="14dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/btnEditProfile"
                        android:layout_centerVertical="true"
                        android:text="@string/profile_information"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:drawableStartCompat="@drawable/ic_person_add"
                        android:drawablePadding="6dp" />

                    <TextView
                        android:id="@+id/btnEditProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="@string/edit_pencil"
                        android:textColor="@color/text_dark"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:background="@drawable/bg_card_form"
                        android:clickable="true"
                        android:focusable="true" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imgDriverProfile"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/ic_person_placeholder"
                        android:background="@drawable/bg_avatar_circle"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/driver_avatar"
                        android:layout_marginEnd="14dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="10dp"
                            android:baselineAligned="false">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/full_name_label" android:textColor="@color/gray_text" android:textSize="11sp"/>
                                <TextView android:id="@+id/tvProfileFullName"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/mike_johnson" android:textColor="@color/text_dark"
                                    android:textSize="13sp" android:textStyle="bold"/>
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/email_label" android:textColor="@color/gray_text" android:textSize="11sp"/>
                                <TextView android:id="@+id/tvProfileEmail"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/john_smith_school_com" android:textColor="@color/text_dark"
                                    android:textSize="11sp" android:textStyle="bold"/>
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:baselineAligned="false">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/phone_label" android:textColor="@color/gray_text" android:textSize="11sp"/>
                                <TextView android:id="@+id/tvProfilePhone"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/_555_0101" android:textColor="@color/text_dark"
                                    android:textSize="13sp" android:textStyle="bold"/>
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/license_number_label" android:textColor="@color/gray_text" android:textSize="11sp"/>
                                <TextView android:id="@+id/tvProfileLicense"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/dl123456" android:textColor="@color/text_dark"
                                    android:textSize="13sp" android:textStyle="bold"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Bus Information Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_cream"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bus_information"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp"
                    app:drawableStartCompat="@drawable/ic_archive"
                    android:drawablePadding="8dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp"
                    android:baselineAligned="false">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/bus_number" android:textColor="@color/gray_text" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvBusNumber"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/bus_001" android:textColor="@color/text_dark"
                            android:textSize="15sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/status" android:textColor="@color/gray_text" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvBusStatus"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/active"
                            android:textColor="@color/black"
                            android:textSize="12sp" android:textStyle="bold"
                            android:background="@drawable/bg_status_active"
                            android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:paddingTop="3dp" android:paddingBottom="3dp"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/capacity" android:textColor="@color/gray_text" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvBusCapacity"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/_40_students" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- School Information Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_cream"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/school_information"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp"
                    app:drawableStartCompat="@drawable/ic_person_add"
                    android:drawablePadding="8dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp"
                    android:baselineAligned="false">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/name" android:textColor="@color/gray_text" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvSchoolName"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/school_name_placeholder" android:textColor="@color/text_dark"
                            android:textSize="13sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/email_label" android:textColor="@color/gray_text" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvSchoolEmail"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/school_name_placeholder" android:textColor="@color/text_dark"
                            android:textSize="13sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/address" android:textColor="@color/gray_text" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvSchoolAddress"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/school_name_placeholder" android:textColor="@color/text_dark"
                        android:textSize="13sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#373636"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <!-- Account Container (Active) -->
        <LinearLayout
            android:id="@+id/containerNavAccount"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageButton
                android:id="@+id/btnNavAccount"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@null"
                android:contentDescription="@string/account"
                android:src="@drawable/ic_nav_account_yellow"
                android:clickable="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/account"
                android:textColor="#FEBE1E"
                android:textSize="11sp" />

            <View
                android:layout_width="20dp"
                android:layout_height="2dp"
                android:layout_marginTop="2dp"
                android:background="#FEBE1E" />
        </LinearLayout>

        <!-- Home Container -->
        <LinearLayout
            android:id="@+id/containerNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageButton
                android:id="@+id/btnNavHome"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@null"
                android:contentDescription="@string/home"
                android:src="@drawable/ic_nav_home_gray"
                android:clickable="false" />

            <TextView
                android:id="@+id/textView12"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home"
                android:textColor="#A99E9E"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Settings Container -->
        <LinearLayout
            android:id="@+id/containerNavSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageButton
                android:id="@+id/btnNavSettings"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@null"
                android:contentDescription="@string/settings"
                android:src="@drawable/ic_nav_settings"
                android:clickable="false" />

            <TextView
                android:id="@+id/textView57"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings"
                android:textColor="#A99E9E"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
