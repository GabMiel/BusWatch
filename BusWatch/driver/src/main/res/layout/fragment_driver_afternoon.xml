<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Greeting Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_greeting_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/good_morning_driver"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed-medium"/>
                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/_9_41_am"
                    android:textColor="#FDFDFD"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Students For: label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/students_for"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed-medium"
                android:layout_marginBottom="10dp"/>

            <!-- Morning / Afternoon Tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_tab_container"
                android:clipChildren="true"
                android:clipToPadding="true"
                android:padding="2dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:id="@+id/tabMorning"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/morning"
                    android:textColor="@color/gray_text"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:letterSpacing="0.04"
                    android:background="@drawable/bg_tab_inactive"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/tabAfternoon"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/afternoon"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:letterSpacing="0.04"
                    android:background="@drawable/bg_tab_active"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- Student List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerStudents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_student_row_afternoon" />

        </LinearLayout>
    </ScrollView>

    <!-- Start Trip Button Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp"
        android:background="#FFFFFF"
        android:elevation="4dp">
        <TextView
            android:id="@+id/btnStartTrip"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="@string/start_trip"
            android:textColor="#000000"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="center"
            android:fontFamily="sans-serif-condensed-medium"
            android:background="@drawable/bg_start_trip"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#373636"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <!-- Account -->
        <LinearLayout
            android:id="@+id/containerNavAccount"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageButton
                android:id="@+id/btnNavAccount"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@null"
                android:contentDescription="@string/account"
                android:src="@drawable/ic_nav_account"
                app:tint="#A99E9E"
                android:clickable="false" />

            <TextView
                android:id="@+id/textView12"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/account"
                android:textColor="#A99E9E"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Home (Active) -->
        <LinearLayout
            android:id="@+id/containerNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageButton
                android:id="@+id/btnNavHome"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@null"
                android:contentDescription="@string/home"
                android:src="@drawable/ic_nav_home"
                app:tint="#FEBE1E"
                android:clickable="false" />

            <TextView
                android:id="@+id/textView56"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home"
                android:textColor="#FEBE1E"
                android:textSize="11sp" />

            <View
                android:layout_width="20dp"
                android:layout_height="2dp"
                android:layout_marginTop="2dp"
                android:background="#FEBE1E" />
        </LinearLayout>

        <!-- Settings -->
        <LinearLayout
            android:id="@+id/containerNavSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageButton
                android:id="@+id/btnNavSettings"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@null"
                android:contentDescription="@string/settings"
                android:src="@drawable/ic_nav_settings"
                app:tint="#A99E9E"
                android:clickable="false" />

            <TextView
                android:id="@+id/textView57"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings"
                android:textColor="#A99E9E"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
