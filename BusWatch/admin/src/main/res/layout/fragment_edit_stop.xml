<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Header Section -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="0dp"
        android:layout_height="75dp"
        android:background="@color/dark_header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnBackEditStop"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back_button"
        android:src="@drawable/ic_back"
        app:layout_constraintBottom_toBottomOf="@id/headerBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/headerBg"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/tvHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="EDIT STOP"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/headerBg"
        app:layout_constraintStart_toEndOf="@id/btnBackEditStop"
        app:layout_constraintTop_toTopOf="@id/headerBg" />

    <!-- Main Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_details_card"
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_margin="16dp">

            <!-- Sub Header (Removed Icon) -->
            <LinearLayout
                android:id="@+id/layoutSubHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STOP INFORMATION"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02" />
            </LinearLayout>

            <!-- Stop Name & Smart Fill -->
            <LinearLayout
                android:id="@+id/layoutStopName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Stop Name" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <EditText android:id="@+id/etStopName"
                        android:layout_width="0dp" android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/rectangle_hollow_with_shadow"
                        android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                        android:inputType="textCapWords" android:hint="e.g. West Gate" android:importantForAutofill="no"/>
                    <ImageButton android:id="@+id/btnSmartFill"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/rectangle_hollow_with_shadow"
                        android:src="@drawable/ic_search"
                        app:tint="@color/black"
                        android:contentDescription="Auto-fill Address"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Map Picker Label -->
            <TextView
                android:id="@+id/tvMapLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pick Location on Map" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>

            <!-- Map View Container -->
            <FrameLayout
                android:id="@+id/mapContainer"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/rectangle_hollow_with_shadow">

                <org.osmdroid.views.MapView
                    android:id="@+id/mapEditStop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <!-- Eye icon (Maximize Button) -->
                <ImageButton
                    android:id="@+id/btnMaximizeMap"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="12dp"
                    android:background="@drawable/circle_shape"
                    android:backgroundTint="#CCFFFFFF"
                    android:src="@drawable/ic_eye"
                    android:padding="8dp"
                    android:elevation="6dp"
                    app:tint="@color/black"
                    android:contentDescription="Maximize Map" />

                <!-- Current Location Button -->
                <ImageButton
                    android:id="@+id/btnMyLocation"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="12dp"
                    android:background="@drawable/circle_shape"
                    android:backgroundTint="#CCFFFFFF"
                    android:src="@drawable/ic_my_location"
                    android:padding="10dp"
                    android:elevation="6dp"
                    app:tint="@color/black"
                    android:contentDescription="My Location" />
            </FrameLayout>

            <!-- Coordinates Display -->
            <TextView
                android:id="@+id/tvCoordinates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:text="Lat: 0.0000, Lng: 0.0000"
                android:textColor="#888888"
                android:textSize="10sp"
                android:gravity="center" />

            <!-- ACTION BUTTONS -->
            <LinearLayout
                android:id="@+id/layoutActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnCancelEditStop"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="CANCEL"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:letterSpacing="0.08"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/btnSaveStopChanges"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="SAVE CHANGES"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:letterSpacing="0.08"
                    android:background="@drawable/bg_button_yellow"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
