<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/dialogContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_details_card"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <RelativeLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="@string/adding_new_route"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                app:drawableStartCompat="@drawable/ic_route"
                android:drawablePadding="10dp" />

            <ImageButton
                android:id="@+id/btnCloseAddRoute"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:contentDescription="@string/close"
                app:tint="@color/black"/>
        </RelativeLayout>

        <!-- Route Name Row -->
        <LinearLayout
            android:id="@+id/layoutRouteName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/route_name" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=" *" android:textColor="#FF0000" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>
            <EditText android:id="@+id/etRouteName"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                android:inputType="textCapWords" android:hint="@string/route_name_placeholder" android:importantForAutofill="no"/>
        </LinearLayout>

        <!-- Driver Selection Row -->
        <LinearLayout
            android:id="@+id/layoutDriver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/choose_driver" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=" *" android:textColor="#FF0000" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>
            <FrameLayout
                android:id="@+id/btnDriverDropdown"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/tvSelectedDriver"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical" android:layout_marginStart="12dp"
                    android:text="@string/select_driver" android:textColor="#666666" android:textSize="14sp" />
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:layout_gravity="end|center_vertical" android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_chevron_down" app:tint="#888888" android:contentDescription="@null"/>
            </FrameLayout>
        </LinearLayout>

        <!-- Bus Selection Row -->
        <LinearLayout
            android:id="@+id/layoutBus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/choose_bus" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=" *" android:textColor="#FF0000" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>
            <FrameLayout
                android:id="@+id/btnBusDropdown"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/tvSelectedBus"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical" android:layout_marginStart="12dp"
                    android:text="@string/select_bus" android:textColor="#666666" android:textSize="14sp" />
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:layout_gravity="end|center_vertical" android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_chevron_down" app:tint="#888888" android:contentDescription="@null"/>
            </FrameLayout>
        </LinearLayout>

        <!-- Morning Schedule -->
        <LinearLayout
            android:id="@+id/layoutMorningTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Morning Schedule" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:id="@+id/tvMorningStart"
                    android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:gravity="center_vertical|start" android:paddingHorizontal="12dp"
                    android:text="Start Time" android:textColor="#666666" android:textSize="13sp"
                    android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/tvMorningEnd"
                    android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:gravity="center_vertical|start" android:paddingHorizontal="12dp"
                    android:text="End Time" android:textColor="#666666" android:textSize="13sp"
                    android:layout_marginStart="4dp" android:clickable="true" android:focusable="true"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Afternoon Schedule -->
        <LinearLayout
            android:id="@+id/layoutAfternoonTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Afternoon Schedule" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:id="@+id/tvAfternoonStart"
                    android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:gravity="center_vertical|start" android:paddingHorizontal="12dp"
                    android:text="Start Time" android:textColor="#666666" android:textSize="13sp"
                    android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/tvAfternoonEnd"
                    android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:gravity="center_vertical|start" android:paddingHorizontal="12dp"
                    android:text="End Time" android:textColor="#666666" android:textSize="13sp"
                    android:layout_marginStart="4dp" android:clickable="true" android:focusable="true"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Bus Capacity Display -->
        <LinearLayout
            android:id="@+id/layoutCapacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Bus Capacity" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tvBusCapacity"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:gravity="center_vertical"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:text="@string/hyphen" android:textColor="#888888" android:textSize="14sp" />
        </LinearLayout>

        <!-- Conductor Selection Row (Optional) -->
        <LinearLayout
            android:id="@+id/layoutConductor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Choose Conductor (Optional)" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <FrameLayout
                android:id="@+id/btnConductorDropdown"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/tvSelectedConductor"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical" android:layout_marginStart="12dp"
                    android:text="Select Conductor" android:textColor="#666666" android:textSize="14sp" />
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:layout_gravity="end|center_vertical" android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_chevron_down" app:tint="#888888" android:contentDescription="@null"/>
            </FrameLayout>
        </LinearLayout>

        <!-- Route Stops Map Selection -->
        <LinearLayout
            android:id="@+id/layoutMapLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="32dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Select Stops for Route" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <FrameLayout
                android:id="@+id/mapContainer"
                android:layout_width="match_parent" android:layout_height="250dp"
                android:background="@drawable/rectangle_hollow">
                <org.osmdroid.views.MapView android:id="@+id/mapRoutePicker"
                    android:layout_width="match_parent" android:layout_height="match_parent" />

                <!-- Eye icon (Maximize Button) -->
                <ImageButton
                    android:id="@+id/btnMaximizeMap"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="12dp"
                    android:background="@drawable/circle_shape"
                    android:backgroundTint="#CCFFFFFF"
                    android:src="@drawable/ic_eye"
                    android:padding="8dp"
                    android:elevation="6dp"
                    app:tint="@color/black"
                    android:contentDescription="Maximize Map" />

                <!-- Current Location Button -->
                <ImageButton
                    android:id="@+id/btnMyLocation"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="12dp"
                    android:background="@drawable/circle_shape"
                    android:backgroundTint="#CCFFFFFF"
                    android:src="@drawable/ic_my_location"
                    android:padding="10dp"
                    android:elevation="6dp"
                    app:tint="@color/black"
                    android:contentDescription="My Location" />
            </FrameLayout>

            <TextView android:id="@+id/tvCurrentCoords"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:text="Lat: 0.0000, Lng: 0.0000"
                android:textColor="#888888" android:textSize="10sp" android:gravity="center" />

            <TextView android:id="@+id/tvSelectedStopsCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:text="Selected: 0 stops"
                android:textSize="11sp" android:textColor="#666666" />
        </LinearLayout>

        <!-- SAVE -->
        <TextView
            android:id="@+id/btnSaveRoute"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="SAVE ROUTE" android:textColor="#000000" android:textSize="16sp"
            android:textStyle="bold" android:gravity="center" android:letterSpacing="0.08"
            android:background="@drawable/bg_button_yellow" android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>
</ScrollView>
