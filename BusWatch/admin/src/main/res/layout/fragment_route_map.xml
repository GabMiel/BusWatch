<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Dark Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@color/dark_header">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/routing"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_alignParentStart="true"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-condensed"
            android:contentDescription="@string/routing"/>
    </RelativeLayout>

    <!-- Navigation Tabs (Styled like Users Fragment) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:orientation="horizontal"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_tab_container"
        android:clipChildren="true"
        android:clipToPadding="true"
        android:padding="2dp">

        <TextView
            android:id="@+id/tabRouteList"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/tab_route_list"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            android:gravity="center"
            android:letterSpacing="0.04"
            android:background="@drawable/bg_tab_inactive"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tabAllRoutesMap"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/tab_all_routes_map"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.04"
            android:background="@drawable/bg_tab_active"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <org.osmdroid.views.MapView
        android:id="@+id/mapAllRoutes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="12dp" />

</LinearLayout>
