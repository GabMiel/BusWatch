<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_details_card"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/adding_new_driver"
            android:textColor="#000000"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            app:drawableStartCompat="@drawable/ic_person_add"
            android:drawablePadding="6dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnCloseAddDriver"
            app:layout_constraintBottom_toBottomOf="@id/btnCloseAddDriver"/>

        <ImageButton
            android:id="@+id/btnCloseAddDriver"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/close"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="@color/black"/>

        <!-- Avatar -->
        <FrameLayout
            android:id="@+id/frameDriverPhoto"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="24dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/btnCloseAddDriver"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/imgDriverPhoto"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_person_placeholder"
                android:background="@drawable/bg_avatar_circle"
                android:scaleType="centerCrop"
                android:contentDescription="@string/photo"/>

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_button_yellow"
                android:text="@string/plus"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"/>
        </FrameLayout>

        <TextView
            android:id="@+id/tvPhotoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/photo"
            android:textColor="#000000"
            android:textSize="11sp"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/frameDriverPhoto"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- First Name -->
        <TextView
            android:id="@+id/tvFirstNameLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/first_name"
            android:textColor="#000000"
            android:textSize="11sp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvPhotoLabel"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvFirstNameAsterisk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/asterisk"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:layout_marginStart="2dp"
            app:layout_constraintBottom_toBottomOf="@id/tvFirstNameLabel"
            app:layout_constraintStart_toEndOf="@id/tvFirstNameLabel"/>

        <EditText
            android:id="@+id/etFirstName"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textSize="13sp"
            android:inputType="textPersonName"
            android:singleLine="true"
            android:importantForAutofill="no"
            android:hint="@string/enter_your_first_name"
            app:layout_constraintTop_toBottomOf="@id/tvFirstNameLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/guideline_vertical_50"/>

        <!-- Middle Name -->
        <TextView
            android:id="@+id/tvMiddleNameLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/middle_name"
            android:textColor="#000000"
            android:textSize="11sp"
            app:layout_constraintTop_toTopOf="@id/tvFirstNameLabel"
            app:layout_constraintStart_toStartOf="@id/etMiddleName"/>

        <EditText
            android:id="@+id/etMiddleName"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:layout_marginStart="5dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textSize="13sp"
            android:inputType="textPersonName"
            android:singleLine="true"
            android:importantForAutofill="no"
            android:hint="@string/enter_your_middle_name"
            app:layout_constraintTop_toBottomOf="@id/tvMiddleNameLabel"
            app:layout_constraintStart_toEndOf="@id/guideline_vertical_50"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Row 1 Warnings -->
        <TextView
            android:id="@+id/tvFirstNameWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:visibility="gone"
            android:text="@string/name_warning"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/etFirstName"
            app:layout_constraintStart_toStartOf="@id/etFirstName"
            app:layout_constraintEnd_toEndOf="@id/etFirstName"/>

        <TextView
            android:id="@+id/tvMiddleNameWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:visibility="gone"
            android:text="@string/name_warning"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/etMiddleName"
            app:layout_constraintStart_toStartOf="@id/etMiddleName"
            app:layout_constraintEnd_toEndOf="@id/etMiddleName"/>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_row1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="etFirstName,etMiddleName,tvFirstNameWarning,tvMiddleNameWarning" />

        <!-- Last Name -->
        <TextView
            android:id="@+id/tvLastNameLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/last_name"
            android:textColor="#000000"
            android:textSize="11sp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/barrier_row1"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvLastNameAsterisk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/asterisk"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:layout_marginStart="2dp"
            app:layout_constraintBottom_toBottomOf="@id/tvLastNameLabel"
            app:layout_constraintStart_toEndOf="@id/tvLastNameLabel"/>

        <EditText
            android:id="@+id/etLastName"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textSize="13sp"
            android:inputType="textPersonName"
            android:singleLine="true"
            android:importantForAutofill="no"
            android:hint="@string/enter_your_last_name"
            app:layout_constraintTop_toBottomOf="@id/tvLastNameLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/guideline_vertical_50"/>

        <!-- Suffix -->
        <TextView
            android:id="@+id/tvSuffixLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/suffix"
            android:textColor="#000000"
            android:textSize="11sp"
            app:layout_constraintTop_toTopOf="@id/tvLastNameLabel"
            app:layout_constraintStart_toStartOf="@id/btnSuffixDropdown"/>

        <FrameLayout
            android:id="@+id/btnSuffixDropdown"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:layout_marginStart="5dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/tvSuffixLabel"
            app:layout_constraintStart_toEndOf="@id/guideline_vertical_50"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView
                android:id="@+id/tvSuffix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="10dp"
                android:text="@string/none"
                android:textColor="#888888"
                android:textSize="13sp" />
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_chevron_down"
                app:tint="#888888"
                android:contentDescription="@string/todo"/>
        </FrameLayout>

        <!-- Row 2 Warning -->
        <TextView
            android:id="@+id/tvLastNameWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:visibility="gone"
            android:text="@string/name_warning"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/etLastName"
            app:layout_constraintStart_toStartOf="@id/etLastName"
            app:layout_constraintEnd_toEndOf="@id/etLastName"/>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_row2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="etLastName,btnSuffixDropdown,tvLastNameWarning" />

        <!-- Email -->
        <TextView
            android:id="@+id/tvEmailLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/email"
            android:textColor="#000000"
            android:textSize="11sp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/barrier_row2"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvEmailAsterisk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/asterisk"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:layout_marginStart="2dp"
            app:layout_constraintBottom_toBottomOf="@id/tvEmailLabel"
            app:layout_constraintStart_toEndOf="@id/tvEmailLabel"/>

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textSize="13sp"
            android:inputType="textEmailAddress"
            android:singleLine="true"
            android:importantForAutofill="no"
            android:hint="@string/enter_your_email"
            app:layout_constraintTop_toBottomOf="@id/tvEmailLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/guideline_vertical_50"/>

        <!-- License No. -->
        <TextView
            android:id="@+id/tvLicenseLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/license_number"
            android:textColor="#000000"
            android:textSize="11sp"
            app:layout_constraintTop_toTopOf="@id/tvEmailLabel"
            app:layout_constraintStart_toStartOf="@id/etLicense"/>

        <TextView
            android:id="@+id/tvLicenseAsterisk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/asterisk"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:layout_marginStart="2dp"
            app:layout_constraintBottom_toBottomOf="@id/tvLicenseLabel"
            app:layout_constraintStart_toEndOf="@id/tvLicenseLabel"/>

        <EditText
            android:id="@+id/etLicense"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:layout_marginStart="5dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textSize="13sp"
            android:inputType="textCapCharacters"
            android:singleLine="true"
            android:importantForAutofill="no"
            android:hint="@string/license_number"
            app:layout_constraintTop_toBottomOf="@id/tvLicenseLabel"
            app:layout_constraintStart_toEndOf="@id/guideline_vertical_50"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Row 3 Warnings -->
        <TextView
            android:id="@+id/tvEmailWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:visibility="gone"
            android:text="@string/invalid_email"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/etEmail"
            app:layout_constraintStart_toStartOf="@id/etEmail"
            app:layout_constraintEnd_toEndOf="@id/etEmail"/>

        <TextView
            android:id="@+id/tvLicenseWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:visibility="gone"
            android:text="@string/license_number_required"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/etLicense"
            app:layout_constraintStart_toStartOf="@id/etLicense"
            app:layout_constraintEnd_toEndOf="@id/etLicense"/>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_row3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="etEmail,etLicense,tvEmailWarning,tvLicenseWarning" />

        <!-- Phone Number -->
        <TextView
            android:id="@+id/tvPhoneLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/contact_phone_number"
            android:textColor="#000000"
            android:textSize="11sp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/barrier_row3"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvPhoneAsterisk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/asterisk"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:layout_marginStart="2dp"
            app:layout_constraintBottom_toBottomOf="@id/tvPhoneLabel"
            app:layout_constraintStart_toEndOf="@id/tvPhoneLabel"/>

        <FrameLayout
            android:id="@+id/btnCountryCode"
            android:layout_width="60dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/tvPhoneLabel"
            app:layout_constraintStart_toStartOf="parent">
            <TextView
                android:id="@+id/tvCountryCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/country_code_ph"
                android:textColor="#000000"
                android:textSize="13sp" />
        </FrameLayout>

        <EditText
            android:id="@+id/etContactNumber"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textSize="13sp"
            android:inputType="phone"
            android:singleLine="true"
            android:importantForAutofill="no"
            android:hint="@string/phone_hint"
            android:maxLength="10"
            app:layout_constraintTop_toTopOf="@id/btnCountryCode"
            app:layout_constraintStart_toEndOf="@id/btnCountryCode"
            app:layout_constraintEnd_toStartOf="@+id/guideline_vertical_50"
            app:layout_constraintHorizontal_bias="0"
            android:layout_marginEnd="5dp"/>

        <!-- Preferred Language -->
        <TextView
            android:id="@+id/tvLanguageLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/preferred_language"
            android:textColor="#000000"
            android:textSize="11sp"
            app:layout_constraintTop_toTopOf="@id/tvPhoneLabel"
            app:layout_constraintStart_toStartOf="@id/btnLanguageDropdown"/>

        <TextView
            android:id="@+id/tvLanguageAsterisk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/asterisk"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:layout_marginStart="2dp"
            app:layout_constraintBottom_toBottomOf="@id/tvLanguageLabel"
            app:layout_constraintStart_toEndOf="@id/tvLanguageLabel"/>

        <FrameLayout
            android:id="@+id/btnLanguageDropdown"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:layout_marginStart="5dp"
            android:background="@drawable/rectangle_hollow_with_shadow"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/tvLanguageLabel"
            app:layout_constraintStart_toEndOf="@id/guideline_vertical_50"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView
                android:id="@+id/tvLanguage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="10dp"
                android:text="@string/select_language"
                android:textColor="#888888"
                android:textSize="13sp" />
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_chevron_down"
                app:tint="#888888"
                android:contentDescription="@string/todo"/>
        </FrameLayout>

        <!-- Row 4 Warning -->
        <TextView
            android:id="@+id/tvPhoneWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:visibility="gone"
            android:text="@string/invalid_phone"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/etContactNumber"
            app:layout_constraintStart_toStartOf="@id/btnCountryCode"
            app:layout_constraintEnd_toEndOf="@id/etContactNumber"/>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_row4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="etContactNumber,btnLanguageDropdown,tvPhoneWarning" />

        <!-- Password -->
        <TextView
            android:id="@+id/tvPasswordLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/password"
            android:textColor="#000000"
            android:textSize="11sp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/barrier_row4"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvPasswordAsterisk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/asterisk"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:layout_marginStart="2dp"
            app:layout_constraintBottom_toBottomOf="@id/tvPasswordLabel"
            app:layout_constraintStart_toEndOf="@id/tvPasswordLabel"/>

        <FrameLayout
            android:id="@+id/flPassword"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="5dp"
            app:layout_constraintTop_toBottomOf="@id/tvPasswordLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/guideline_vertical_50">
            <EditText android:id="@+id/etPassword"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:paddingStart="10dp" android:paddingEnd="40dp"
                android:textSize="13sp" android:inputType="textPassword" android:singleLine="true"
                android:importantForAutofill="no"
                android:hint="@string/enter_password_hint"/>
            <ImageButton
                android:id="@+id/btnViewPassword"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_eye_off"
                app:tint="#888888"
                android:contentDescription="@string/show_password"/>
        </FrameLayout>

        <!-- Confirm Password -->
        <TextView
            android:id="@+id/tvConfirmPasswordLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/confirm_password"
            android:textColor="#000000"
            android:textSize="11sp"
            app:layout_constraintTop_toTopOf="@id/tvPasswordLabel"
            app:layout_constraintStart_toStartOf="@id/flConfirmPassword"/>

        <TextView
            android:id="@+id/tvConfirmPasswordAsterisk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/asterisk"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:layout_marginStart="2dp"
            app:layout_constraintBottom_toBottomOf="@id/tvConfirmPasswordLabel"
            app:layout_constraintStart_toEndOf="@id/tvConfirmPasswordLabel"/>

        <FrameLayout
            android:id="@+id/flConfirmPassword"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:layout_marginStart="5dp"
            app:layout_constraintTop_toBottomOf="@id/tvConfirmPasswordLabel"
            app:layout_constraintStart_toEndOf="@id/guideline_vertical_50"
            app:layout_constraintEnd_toEndOf="parent">
            <EditText android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:paddingStart="10dp" android:paddingEnd="40dp"
                android:textSize="13sp" android:inputType="textPassword" android:singleLine="true"
                android:importantForAutofill="no"
                android:hint="@string/re_enter_password"/>
            <ImageButton
                android:id="@+id/btnViewConfirmPassword"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_eye_off"
                app:tint="#888888"
                android:contentDescription="@string/show_password"/>
        </FrameLayout>

        <!-- Row 5 Warnings -->
        <TextView
            android:id="@+id/tvPasswordWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:visibility="gone"
            android:text="@string/weak_password"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/flPassword"
            app:layout_constraintStart_toStartOf="@id/flPassword"
            app:layout_constraintEnd_toEndOf="@id/flPassword"/>

        <TextView
            android:id="@+id/tvConfirmPasswordWarning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:visibility="gone"
            android:text="@string/passwords_do_not_match"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/flConfirmPassword"
            app:layout_constraintStart_toStartOf="@id/flConfirmPassword"
            app:layout_constraintEnd_toEndOf="@id/flConfirmPassword"/>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_row5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="flPassword,flConfirmPassword,tvPasswordWarning,tvConfirmPasswordWarning" />

        <!-- SAVE -->
        <TextView
            android:id="@+id/btnSaveDriver"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="32dp"
            android:text="@string/save_caps"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.08"
            android:background="@drawable/bg_button_yellow"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/barrier_row5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_vertical_50"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
