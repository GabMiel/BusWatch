<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_form">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@id/btnCloseAddDriver"
                android:text="@string/adding_new_driver"
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                app:drawableStartCompat="@drawable/ic_person_add"
                android:drawablePadding="6dp" />

            <ImageButton
                android:id="@+id/btnCloseAddDriver"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:contentDescription="@string/close"/>
        </RelativeLayout>

        <!-- Avatar — tappable to pick image -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <FrameLayout
                android:id="@+id/frameDriverPhoto"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/imgDriverPhoto"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_person_placeholder"
                    android:background="@drawable/bg_avatar_circle"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/photo"/>

                <!-- Camera overlay badge -->
                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_button_yellow"
                    android:text="@string/plus"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/photo"
                android:textColor="@color/black" android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- First Name / Email -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="14dp"
            android:baselineAligned="false">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/first_name" android:textColor="@color/black" android:textSize="11sp" android:layout_marginBottom="4dp"
                    android:labelFor="@+id/etFirstName"/>
                <EditText android:id="@+id/etFirstName"
                    android:layout_width="match_parent" android:layout_height="40dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:textSize="13sp" android:inputType="textPersonName" android:singleLine="true"
                    android:importantForAutofill="no"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/email" android:textColor="@color/black" android:textSize="11sp" android:layout_marginBottom="4dp"
                    android:labelFor="@+id/etEmail"/>
                <EditText android:id="@+id/etEmail"
                    android:layout_width="match_parent" android:layout_height="40dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:textSize="13sp" android:inputType="textEmailAddress" android:singleLine="true"
                    android:importantForAutofill="no"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Middle Name / Contact Number -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="14dp"
            android:baselineAligned="false">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/middle_name" android:textColor="@color/black" android:textSize="11sp" android:layout_marginBottom="4dp"
                    android:labelFor="@+id/etMiddleName"/>
                <EditText android:id="@+id/etMiddleName"
                    android:layout_width="match_parent" android:layout_height="40dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:textSize="13sp" android:inputType="textPersonName" android:singleLine="true"
                    android:importantForAutofill="no"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/contact_phone" android:textColor="@color/black" android:textSize="11sp" android:layout_marginBottom="4dp"
                    android:labelFor="@+id/etContactNumber"/>
                <EditText android:id="@+id/etContactNumber"
                    android:layout_width="match_parent" android:layout_height="40dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:textSize="13sp" android:inputType="phone" android:singleLine="true"
                    android:importantForAutofill="no"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Last Name / License Number -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="14dp"
            android:baselineAligned="false">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/last_name" android:textColor="@color/black" android:textSize="11sp" android:layout_marginBottom="4dp"
                    android:labelFor="@+id/etLastName"/>
                <EditText android:id="@+id/etLastName"
                    android:layout_width="match_parent" android:layout_height="40dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:textSize="13sp" android:inputType="textPersonName" android:singleLine="true"
                    android:importantForAutofill="no"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/license_number" android:textColor="@color/black" android:textSize="11sp" android:layout_marginBottom="4dp"
                    android:labelFor="@+id/etLicenseNumber"/>
                <EditText android:id="@+id/etLicenseNumber"
                    android:layout_width="match_parent" android:layout_height="40dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:textSize="13sp" android:inputType="text" android:singleLine="true"
                    android:importantForAutofill="no"
                    tools:ignore="TextFields" />
            </LinearLayout>
        </LinearLayout>

        <!-- Suffix / Password -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="14dp"
            android:baselineAligned="false">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/suffix" android:textColor="@color/black" android:textSize="11sp" android:layout_marginBottom="4dp"
                    android:labelFor="@+id/etSuffix"/>
                <EditText android:id="@+id/etSuffix"
                    android:layout_width="match_parent" android:layout_height="40dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:textSize="13sp" android:inputType="text" android:singleLine="true"
                    android:importantForAutofill="no"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/password" android:textColor="@color/black" android:textSize="11sp" android:layout_marginBottom="4dp"
                    android:labelFor="@+id/etPassword"/>
                <EditText android:id="@+id/etPassword"
                    android:layout_width="match_parent" android:layout_height="40dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:textSize="13sp" android:inputType="textPassword" android:singleLine="true"
                    android:importantForAutofill="no"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Confirm Password full width -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="24dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/confirm_password" android:textColor="@color/black" android:textSize="11sp" android:layout_marginBottom="4dp"
                android:labelFor="@+id/etConfirmPassword"/>
            <EditText android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent" android:layout_height="40dp"
                android:background="@drawable/bg_input_field"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:textSize="13sp" android:inputType="textPassword" android:singleLine="true"
                android:importantForAutofill="no"/>
        </LinearLayout>

        <!-- SAVE — yellow full width rounded -->
        <TextView
            android:id="@+id/btnSaveDriver"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/save_caps"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.08"
            android:background="@drawable/bg_button_yellow"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>
</ScrollView>
