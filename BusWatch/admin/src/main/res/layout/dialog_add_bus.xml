<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_details_card"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@id/btnCloseAddBus"
                android:text="@string/adding_new_bus"
                android:textColor="#000000"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                app:drawableStartCompat="@drawable/ic_bus_logo"
                android:drawablePadding="6dp" />

            <ImageButton
                android:id="@+id/btnCloseAddBus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:contentDescription="@string/close"
                app:tint="@color/black"/>
        </RelativeLayout>

        <!-- Row 1: Bus Number -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:id="@+id/tvBusNumberLabel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/bus_number" android:textColor="#000000" android:textSize="11sp" android:layout_marginBottom="4dp"
                    android:labelFor="@+id/etBusNumber"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/asterisk" android:textColor="#FF0000" android:textSize="11sp" android:layout_marginStart="2dp"
                    android:importantForAccessibility="no"/>
            </LinearLayout>
            <EditText android:id="@+id/etBusNumber"
                android:layout_width="match_parent" android:layout_height="40dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:textSize="13sp" android:inputType="number" android:singleLine="true"
                android:importantForAutofill="no"
                tools:ignore="NumberIdentification" />
        </LinearLayout>

        <!-- Row 2: Vehicle Type and Capacity -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="4dp"
            android:baselineAligned="false">

            <!-- Vehicle Type -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1.5" android:orientation="vertical" android:layout_marginEnd="10dp">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/vehicle_type" android:textColor="#000000" android:textSize="11sp" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/asterisk" android:textColor="#FF0000" android:textSize="11sp" android:layout_marginStart="2dp"
                        android:importantForAccessibility="no"/>
                </LinearLayout>
                <FrameLayout
                    android:id="@+id/btnVehicleTypeDropdown"
                    android:layout_width="match_parent" android:layout_height="40dp"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/vehicle_type">
                    <TextView
                        android:id="@+id/tvSelectedVehicleType"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="10dp"
                        android:text="@string/select_type"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_chevron_down"
                        app:tint="#888888"
                        android:contentDescription="@null"/>
                </FrameLayout>
            </LinearLayout>

            <!-- Capacity -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:id="@+id/tvCapacityInputLabel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/capacity" android:textColor="#000000" android:textSize="11sp" android:layout_marginBottom="4dp"
                        android:labelFor="@+id/etCapacity"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/asterisk" android:textColor="#FF0000" android:textSize="11sp" android:layout_marginStart="2dp"
                        android:importantForAccessibility="no"/>
                </LinearLayout>
                <EditText android:id="@+id/etCapacity"
                    android:layout_width="match_parent" android:layout_height="40dp"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:textSize="13sp" android:inputType="number" android:singleLine="true"
                    android:importantForAutofill="no"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Capacity Feedback Row -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvCapacityLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="@drawable/soft_corner"
                android:visibility="gone"
                android:textColor="@color/white"
                android:layout_marginEnd="8dp"
                tools:ignore="SmallSp"/>

            <TextView
                android:id="@+id/tvCapacityWarning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/error_red"
                android:visibility="gone"
                tools:ignore="SmallSp"/>
        </LinearLayout>

        <!-- Row 3: Plate Number (Optional) -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="24dp">
            <TextView android:id="@+id/tvPlateNumberLabel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/plate_number_label" android:textColor="#000000" android:textSize="11sp" android:layout_marginBottom="4dp"
                android:labelFor="@+id/etPlateNumber"/>
            <EditText android:id="@+id/etPlateNumber"
                android:layout_width="match_parent" android:layout_height="40dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:textSize="13sp" android:inputType="number" android:singleLine="true"
                android:digits="0123456789"
                android:importantForAutofill="no"
                tools:ignore="NumberIdentification" />
        </LinearLayout>

        <!-- SAVE — yellow full width rounded -->
        <TextView
            android:id="@+id/btnSaveBus"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/save_caps"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.08"
            android:background="@drawable/bg_button_yellow"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>
</ScrollView>
