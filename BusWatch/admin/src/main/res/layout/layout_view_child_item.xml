<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_details_card"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Collapsible Header -->
    <LinearLayout
        android:id="@+id/btnToggleChildInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        tools:ignore="UseCompoundDrawables">

        <TextView
            android:id="@+id/tvChildHeaderName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:drawablePadding="8dp"
            android:gravity="center_vertical"
            android:text="CHILD NAME"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            app:drawableStartCompat="@drawable/child"
            tools:ignore="HardcodedText" />

        <ImageView
            android:id="@+id/ivChildChevron"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_chevron_down"
            app:tint="@color/black"
            android:rotation="-90"
            android:contentDescription="@null" />
    </LinearLayout>

    <!-- Collapsible Content -->
    <LinearLayout
        android:id="@+id/layoutChildContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Profile Photo -->
        <ImageView
            android:id="@+id/imgChild"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:src="@drawable/ic_person_placeholder"
            android:background="@drawable/bg_avatar_circle"
            android:scaleType="centerCrop"
            android:contentDescription="@string/child_photo" />

        <!-- Name Details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="FIRST NAME" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                    tools:ignore="SmallSp,HardcodedText" />
                <TextView android:id="@+id/tvChildFirstName"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                    android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="MIDDLE NAME" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                    tools:ignore="SmallSp,HardcodedText" />
                <TextView android:id="@+id/tvChildMiddleName"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                    android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.3"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="LAST NAME" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                    tools:ignore="SmallSp,HardcodedText" />
                <TextView android:id="@+id/tvChildLastName"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                    android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.7"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SUFFIX" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                    tools:ignore="SmallSp,HardcodedText" />
                <TextView android:id="@+id/tvChildSuffix"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                    android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SECTION" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                    tools:ignore="SmallSp,HardcodedText" />
                <TextView android:id="@+id/tvChildSection"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                    android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="GRADE" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                    tools:ignore="SmallSp,HardcodedText" />
                <TextView android:id="@+id/tvChildGrade"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                    android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SCHOOL" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                tools:ignore="SmallSp,HardcodedText" />
            <TextView android:id="@+id/tvChildSchool"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="24dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="HOME ADDRESS" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                tools:ignore="SmallSp,HardcodedText" />
            <TextView android:id="@+id/tvChildAddress"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
        </LinearLayout>

        <!-- Medical Information Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="MEDICAL INFORMATION"
            android:textColor="@color/black"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="BLOOD TYPE" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                tools:ignore="SmallSp,HardcodedText" />
            <TextView android:id="@+id/tvChildBloodType"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ALLERGIES" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                tools:ignore="SmallSp,HardcodedText" />
            <TextView android:id="@+id/tvChildAllergies"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="MEDICAL CONDITION" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                tools:ignore="SmallSp,HardcodedText" />
            <TextView android:id="@+id/tvChildConditions"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="CURRENT MEDICATIONS" android:textColor="@color/gray_text" android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="4dp"
                tools:ignore="SmallSp,HardcodedText" />
            <TextView android:id="@+id/tvChildMedications"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                android:gravity="center_vertical" android:textColor="@color/black" android:text="@string/placeholder_hyphen"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
