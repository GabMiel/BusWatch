<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Dark Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@color/dark_header"
        android:text="@string/dashboard"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-condensed"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:letterSpacing="0.1" />

    <!-- 2x2 Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:padding="16dp"
        android:layout_marginTop="8dp">

        <!-- Total Parents -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp" android:layout_height="130dp"
            android:layout_columnWeight="1" android:layout_margin="8dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="@color/yellow_primary"
            app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center" android:padding="12dp">
                <TextView
                    android:id="@+id/tvCountParents"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/count_zero" android:textColor="@color/black"
                    android:textSize="34sp" android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/total_parents_caps" android:textColor="@color/black"
                    android:textSize="12sp" android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif"
                    android:textAllCaps="true"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Total Drivers -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp" android:layout_height="130dp"
            android:layout_columnWeight="1" android:layout_margin="8dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="@color/yellow_primary"
            app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center" android:padding="12dp">
                <TextView
                    android:id="@+id/tvCountDrivers"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/count_zero" android:textColor="@color/black"
                    android:textSize="34sp" android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/total_drivers_caps" android:textColor="@color/black"
                    android:textSize="12sp" android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif"
                    android:textAllCaps="true"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Total Bus -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp" android:layout_height="130dp"
            android:layout_columnWeight="1" android:layout_margin="8dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="@color/yellow_primary"
            app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center" android:padding="12dp">
                <TextView
                    android:id="@+id/tvCountBuses"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/count_zero" android:textColor="@color/black"
                    android:textSize="34sp" android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/total_bus_caps" android:textColor="@color/black"
                    android:textSize="12sp" android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif"
                    android:textStyle="bold"
                    android:textAllCaps="true"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Pending Parents -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp" android:layout_height="130dp"
            android:layout_columnWeight="1" android:layout_margin="8dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="@color/yellow_primary"
            app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center" android:padding="12dp">
                <TextView
                    android:id="@+id/tvCountPending"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/count_zero" android:textColor="@color/black"
                    android:textSize="34sp" android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/pending_parents_caps_2" android:textColor="@color/black"
                    android:textSize="12sp" android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif"
                    android:textAllCaps="true"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </GridLayout>

</LinearLayout>
