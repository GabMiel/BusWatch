<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Header Section -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="0dp"
        android:layout_height="75dp"
        android:background="@color/dark_header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnBackEditDriver"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back"
        android:src="@drawable/ic_back"
        app:layout_constraintBottom_toBottomOf="@id/headerBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/headerBg"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/tvHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/edit_driver_information"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/headerBg"
        app:layout_constraintStart_toEndOf="@id/btnBackEditDriver"
        app:layout_constraintTop_toTopOf="@id/headerBg" />

    <!-- Main Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Information Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_details_card"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="24dp">

                <!-- Row Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:text="@string/driver_information"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02" />

                <!-- Profile Photo -->
                <FrameLayout
                    android:id="@+id/rlEditDriverAvatar"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="32dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/imgDriver"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:src="@drawable/ic_person_placeholder"
                        android:background="@drawable/bg_avatar_circle"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/photo" />

                    <TextView
                        android:id="@+id/btnChangeDriverPhoto"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_button_yellow"
                        android:text="@string/plus"
                        android:textColor="#000000"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </FrameLayout>

                <!-- Name Row (Horizontal) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/first_name" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/etFirstName"
                            android:layout_width="match_parent" android:layout_height="48dp"
                            android:background="@drawable/rectangle_hollow_with_shadow"
                            android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                            android:inputType="textPersonName" android:hint="@string/enter_your_first_name" android:importantForAutofill="no"/>
                        <TextView android:id="@+id/tvFirstNameWarning" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textColor="#FF0000" android:textSize="11sp" android:visibility="gone" android:text="@string/name_warning" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/middle_name" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/etMiddleName"
                            android:layout_width="match_parent" android:layout_height="48dp"
                            android:background="@drawable/rectangle_hollow_with_shadow"
                            android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                            android:inputType="textPersonName" android:hint="@string/none" android:importantForAutofill="no"/>
                        <TextView android:id="@+id/tvMiddleNameWarning" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textColor="#FF0000" android:textSize="11sp" android:visibility="gone" android:text="@string/name_warning" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Last Name & Suffix Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.3"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/last_name" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/etLastName"
                            android:layout_width="match_parent" android:layout_height="48dp"
                            android:background="@drawable/rectangle_hollow_with_shadow"
                            android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                            android:inputType="textPersonName" android:hint="@string/enter_your_last_name" android:importantForAutofill="no"/>
                        <TextView android:id="@+id/tvLastNameWarning" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textColor="#FF0000" android:textSize="11sp" android:visibility="gone" android:text="@string/name_warning" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.7"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/suffix" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <FrameLayout android:id="@+id/btnSuffixDropdown"
                            android:layout_width="match_parent" android:layout_height="48dp"
                            android:background="@drawable/rectangle_hollow_with_shadow"
                            android:clickable="true" android:focusable="true">
                            <TextView android:id="@+id/tvSuffix"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical" android:layout_marginStart="12dp"
                                android:text="@string/none" android:textColor="#666666" android:textSize="14sp"/>
                            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_gravity="end|center_vertical"
                                android:layout_marginEnd="8dp" android:src="@drawable/ic_chevron_down" app:tint="#888888" android:contentDescription="@null"/>
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Email Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/email_label" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <EditText android:id="@+id/etEmail"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/rectangle_hollow_with_shadow"
                        android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                        android:inputType="textEmailAddress" android:hint="@string/enter_email" android:importantForAutofill="no"/>
                    <TextView android:id="@+id/tvEmailWarning" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="#FF0000" android:textSize="11sp" android:visibility="gone" android:text="@string/invalid_email" />
                </LinearLayout>

                <!-- License No. Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/license_number_label" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <EditText android:id="@+id/etLicenseNumber"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/rectangle_hollow_with_shadow"
                        android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                        android:inputType="textCapCharacters" android:maxLength="10" android:hint="@string/dl123456" android:importantForAutofill="no"/>
                </LinearLayout>

                <!-- Phone & Language Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/phone_label" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:orientation="horizontal">
                            <FrameLayout android:id="@+id/btnCountryCode"
                                android:layout_width="60dp" android:layout_height="match_parent"
                                android:background="@drawable/rectangle_hollow_with_shadow">
                                <TextView android:id="@+id/tvCountryCode"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center" android:text="@string/country_code_ph" android:textColor="#000000" android:textSize="14sp"/>
                            </FrameLayout>
                            <EditText android:id="@+id/etPhone"
                                android:layout_width="match_parent" android:layout_height="match_parent"
                                android:layout_marginStart="4dp"
                                android:background="@drawable/rectangle_hollow_with_shadow"
                                android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                                android:inputType="phone" android:hint="@string/phone_hint" android:maxLength="12" android:importantForAutofill="no"/>
                        </LinearLayout>
                        <TextView android:id="@+id/tvPhoneWarning" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textColor="#FF0000" android:textSize="11sp" android:visibility="gone" android:text="@string/invalid_phone" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.8"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/preferred_language" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <FrameLayout android:id="@+id/btnLanguageDropdown"
                            android:layout_width="match_parent" android:layout_height="48dp"
                            android:background="@drawable/rectangle_hollow_with_shadow"
                            android:clickable="true" android:focusable="true">
                            <TextView android:id="@+id/tvLanguage"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical" android:layout_marginStart="12dp"
                                android:text="@string/english" android:textColor="#666666" android:textSize="14sp"/>
                            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_gravity="end|center_vertical"
                                android:layout_marginEnd="8dp" android:src="@drawable/ic_chevron_down" app:tint="#888888" android:contentDescription="@null"/>
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Buttons Row (CANCEL and SAVE CHANGES) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <TextView
                    android:id="@+id/btnCancelEditDriver"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/cancel_caps"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:letterSpacing="0.08"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/btnSaveDriverChanges"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/save_changes_caps"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:letterSpacing="0.08"
                    android:background="@drawable/bg_button_yellow"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
