<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/dialogContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_details_card"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <RelativeLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="Add Stop"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

            <ImageButton
                android:id="@+id/btnCloseAddStop"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:contentDescription="Close"
                app:tint="@color/black" />
        </RelativeLayout>

        <!-- Stop Name & Smart Fill -->
        <LinearLayout
            android:id="@+id/layoutStopName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Stop Name" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=" *" android:textColor="#FF0000" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <EditText android:id="@+id/etStopName"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:textSize="14sp"
                    android:inputType="textCapWords" android:hint="e.g. West Gate" android:importantForAutofill="no"/>
                <ImageButton android:id="@+id/btnSmartFill"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/rectangle_hollow_with_shadow"
                    android:src="@drawable/ic_search"
                    app:tint="@color/black"
                    android:contentDescription="Auto-fill Address"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Map Picker Label -->
        <LinearLayout
            android:id="@+id/layoutMapLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Pick Location on Map" android:textColor="#444444" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text=" *" android:textColor="#FF0000" android:textSize="12sp" android:textStyle="bold"/>
        </LinearLayout>

        <!-- Map View Container -->
        <FrameLayout
            android:id="@+id/mapContainer"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/rectangle_hollow_with_shadow">

            <org.osmdroid.views.MapView
                android:id="@+id/mapPicker"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Maximize Button (Eye icon) -->
            <ImageButton
                android:id="@+id/btnMaximizeMap"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:background="@drawable/circle_shape"
                android:backgroundTint="#CCFFFFFF"
                android:src="@drawable/ic_eye"
                android:padding="8dp"
                android:elevation="6dp"
                app:tint="@color/black"
                android:contentDescription="Maximize Map" />

            <!-- Current Location Button -->
            <ImageButton
                android:id="@+id/btnMyLocation"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="12dp"
                android:background="@drawable/circle_shape"
                android:backgroundTint="#CCFFFFFF"
                android:src="@drawable/ic_my_location"
                android:padding="10dp"
                android:elevation="6dp"
                app:tint="@color/black"
                android:contentDescription="My Location" />
        </FrameLayout>

        <!-- Coordinates Display -->
        <TextView
            android:id="@+id/tvCoordinates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="Lat: 0.0000, Lng: 0.0000"
            android:textColor="#888888"
            android:textSize="10sp"
            android:gravity="center" />

        <!-- ACTION BUTTONS -->
        <LinearLayout
            android:id="@+id/layoutActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnAddAnother"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="ADD &amp; CONTINUE"
                android:textColor="#000000"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/rectangle_hollow_with_shadow"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnSaveStop"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="ADD &amp; CLOSE"
                android:textColor="#000000"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_button_yellow"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
