<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Header Section (Matched with Parent Approval Detail) -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="0dp"
        android:layout_height="75dp"
        android:background="@color/dark_header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnBackMapDetail"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back_button"
        android:src="@drawable/ic_back"
        app:layout_constraintBottom_toBottomOf="@id/headerBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/headerBg"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/tvHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/location_change_request"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/headerBg"
        app:layout_constraintStart_toEndOf="@id/btnBackMapDetail"
        app:layout_constraintTop_toTopOf="@id/headerBg" />

    <!-- Main Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Parent Information Card (Now at the Top) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardParentInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_details_card"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/icProfile"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@string/user_icon"
                    android:src="@drawable/ic_person_placeholder"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/black" />

                <TextView
                    android:id="@+id/tvParentInfoLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/parent_information"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/icProfile"
                    app:layout_constraintStart_toEndOf="@id/icProfile"
                    app:layout_constraintTop_toTopOf="@id/icProfile" />

                <ImageView
                    android:id="@+id/imgParent"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:contentDescription="@string/profile_avatar"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_person_placeholder"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/icProfile" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="@id/imgParent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/imgParent"
                    app:layout_constraintTop_toTopOf="@id/imgParent">
                    <TextView android:id="@+id/tvParentFullName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/placeholder_hyphen" android:textColor="@color/black" android:textSize="15sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvParentPhone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="@string/placeholder_hyphen" android:textColor="@color/gray_text" android:textSize="12sp" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Request Context (Student Name) -->
            <TextView
                android:id="@+id/tvStudentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="@string/mike_johnson"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Current Home Location Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardCurrentLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_details_card"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/icCurrentLocation"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@string/todo"
                    android:src="@drawable/globe"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/gray_text" />

                <TextView
                    android:id="@+id/tvCurrentLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/current_pickup_location"
                    android:textColor="@color/gray_text"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/icCurrentLocation"
                    app:layout_constraintStart_toEndOf="@id/icCurrentLocation"
                    app:layout_constraintTop_toTopOf="@id/icCurrentLocation" />

                <TextView
                    android:id="@+id/tvCurrentAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/placeholder_hyphen"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvCurrentLabel" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:layout_constraintTop_toBottomOf="@id/tvCurrentAddress">
                    <org.osmdroid.views.MapView
                        android:id="@+id/mapCurrentLocation"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </androidx.cardview.widget.CardView>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Proposed New Location Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardProposedLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_details_card"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/icProposedLocation"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@string/todo"
                    android:src="@drawable/globe"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/yellow_dark" />

                <TextView
                    android:id="@+id/tvProposedLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/proposed_new_location"
                    android:textColor="@color/yellow_dark"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/icProposedLocation"
                    app:layout_constraintStart_toEndOf="@id/icProposedLocation"
                    app:layout_constraintTop_toTopOf="@id/icProposedLocation" />

                <TextView
                    android:id="@+id/tvPendingAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/placeholder_hyphen"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvProposedLabel" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:layout_constraintTop_toBottomOf="@id/tvPendingAddress">
                    <org.osmdroid.views.MapView
                        android:id="@+id/mapPendingLocation"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </androidx.cardview.widget.CardView>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Action Buttons (Matched with Parent Approval Detail) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRejectMap"
                    android:layout_width="130dp"
                    android:layout_height="54dp"
                    android:layout_marginEnd="12dp"
                    android:text="@string/reject_caps"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="#F44336"
                    app:cornerRadius="27dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApproveMap"
                    android:layout_width="130dp"
                    android:layout_height="54dp"
                    android:text="@string/approve_caps"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="#4CAF50"
                    app:cornerRadius="27dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
