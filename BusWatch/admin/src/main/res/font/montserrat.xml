<?xml version="1.0" encoding="utf-8"?>
<!--
    To use real Montserrat:
    1. Download from https://fonts.google.com/specimen/Montserrat
    2. Place montserrat_regular.ttf and montserrat_bold.ttf in res/font/
    3. Replace this file with the font-family XML below (uncomment it)

    <font-family xmlns:android="http://schemas.android.com/apk/res/android">
        <font android:fontStyle="normal" android:fontWeight="400"
              android:font="@font/montserrat_regular"/>
        <font android:fontStyle="normal" android:fontWeight="700"
              android:font="@font/montserrat_bold"/>
    </font-family>

    Until then, the app uses Android's built-in sans-serif-condensed as fallback.
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android">
</font-family>
