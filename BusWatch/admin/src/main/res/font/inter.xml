<?xml version="1.0" encoding="utf-8"?>
<!--
    To use real Inter:
    1. Download from https://fonts.google.com/specimen/Inter
    2. Place inter_regular.ttf and inter_bold.ttf in res/font/
    3. Replace this file with the font-family XML below (uncomment it)

    <font-family xmlns:android="http://schemas.android.com/apk/res/android">
        <font android:fontStyle="normal" android:fontWeight="400"
              android:font="@font/inter_regular"/>
        <font android:fontStyle="normal" android:fontWeight="700"
              android:font="@font/inter_bold"/>
    </font-family>

    Until then, the app uses Android's built-in sans-serif as fallback.
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android">
</font-family>
